<t name="Custom Portal Login" t-name="custom_portal_login.custom_login_template">
  <t t-call="website.layout">
      <div id="wrap" class="oe_structure">
          
          <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
          <!-- استدعاء خط كايرو من جوجل -->
          <link rel="preconnect" href="https://fonts.googleapis.com"/>
          <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
          <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&amp;display=swap" rel="stylesheet"/>

          <style>
              .custom-footer, footer, nav { display:none}
              #wrap {padding-bottom: 0 !important;}
            *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
              :root {
                --gold: #C9982A; --gold-dark: #A87B1E; --gold-light: rgba(201,152,42,0.15);
                --navy: #0D1B2E; --white: #FFFFFF;
                --text-muted: #8A8A8A; --border: #E2DDD4; --input-bg: #FAFAF8;
              }
             html,
body {
  font-family: "Cairo", sans-serif;
  background: #000;
  color: var(--white);
  overflow-x: hidden;
  min-height: 100vh;
  margin: 0;
  padding: 0;
}

#wrap {
  width: 100%;
  overflow: visible;
}
               
              /* ── HERO ── */
             .hero-section {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  width: 100%;
  overflow: hidden;
}

              .hero-bg { position: absolute; inset: 0; z-index: 0; background: var(--navy); }
              .hero-bg img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
              @media (min-width: 961px) {
                .hero-bg img { object-position: 102% 10%; }
              }
              .hero-bg::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to left, rgba(13,27,46,0.15) 0%, rgba(13,27,46,0.5) 38%, rgba(13,27,46,0.9) 100%); }
               
              /* ── HERO BODY ── */
              .hero-body {
  position: relative;
  z-index: 10;

  flex: 1 1 auto;
  min-height: 0;

  display: flex;
  align-items: center;
  justify-content: space-between;

  gap: 40px;

  padding: 20px 60px;

  overflow: hidden;
}
*,
*::before,
*::after {
  font-family: "Cairo", sans-serif !important;
}
html,
body,
#wrap,
#wrapwrap,
.o_rtl,
.hero-section,
.hero-section * {
  font-family: "Cairo", sans-serif !important;
}
              .hero-copy { flex: 1; max-width: 520px; }
              .hero-title { font-size: 54px; font-weight: 700; color: var(--white); line-height: 1.15; margin-bottom: 14px; }
              .hero-title em { font-style: normal; color: var(--gold); font-weight: 900; display: block; }
              .hero-desc { font-size: 15px; color: rgba(255,255,255,0.65); line-height: 1.85; margin-bottom: 36px; }
              .features-row { display: flex; gap: 28px; }
              .feat { display: flex; flex-direction: column; align-items: center; gap: 8px; }
              .feat-icon { width: 50px; height: 50px; border-radius: 50%; border: 1.5px solid rgba(201,152,42,0.5); background: rgba(201,152,42,0.1); display: flex; align-items: center; justify-content: center; transition: background 0.2s, border-color 0.2s; }
              .feat-icon:hover { background: rgba(201,152,42,0.2); border-color: rgba(201,152,42,0.8); }
              .feat-icon svg { width: 22px; height: 22px; stroke: var(--gold); fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
              .feat-label { font-size: 13px; color: rgba(255,255,255,0.8); font-weight: 500; }
               
              /* ── LOGIN CARD ── */
              .login-card {
  width: 390px;
  flex-shrink: 0;
  background: var(--white);
  border-radius: 18px;
  padding: 6px 26px 10px;
  direction: rtl;
}
              .card-head { text-align: center; margin-bottom: 8px; }
              .card-title { font-size: 22px; font-weight: 800; color: var(--navy); margin-bottom: 5px; }
              .card-sub { font-size: 13px; color: var(--text-muted); }
              .field { margin-bottom: 2px; }
              .field-label { display: block; font-size: 13px; font-weight: 700; color: #2a2a2a; margin-bottom: 7px; }
              #ref_label { min-height: 25px; }
              .input-wrap { position: relative; }
              .field-input, .field-select { width: 100%; height: 44px; border: 1.5px solid var(--border); border-radius: 10px; padding: 0 14px 0 42px; font-family: "Cairo", sans-serif; font-size: 16px; color: #333; background: var(--input-bg); direction: rtl; text-align: right; outline: none; appearance: none; transition: border-color 0.2s, box-shadow 0.2s; }
              .login-card input:not([type="checkbox"]), .login-card select, .login-card textarea { font-size: 16px; }
              .field-input::placeholder { color: #c5bfb5; }
              .field-input:focus, .field-select:focus { border-color: var(--gold); background: #fff; box-shadow: 0 0 0 3px rgba(201,152,42,0.12); }
              .in-icon { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); color: #c5bfb5; display: flex; align-items: center; pointer-events: none; }
              .in-icon svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
              .eye-btn { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); background: none; border: none; padding: 0; cursor: pointer; color: #c5bfb5; display: flex; transition: color 0.15s; }
              .eye-btn:hover { color: var(--gold); }
              .eye-btn svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
              .form-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
              .remember { display: flex; align-items: center; gap: 6px; font-size: 12.5px; color: #444; font-weight: 500; cursor: pointer; }
              .remember input { accent-color: var(--gold); width: 14px; height: 14px; cursor: pointer; }
              .forgot { font-size: 12.5px; color: var(--gold); text-decoration: none; font-weight: 600; }
              .forgot:hover { color: var(--gold-dark); text-decoration: underline; }
              .btn-login { width: 100%; height: 48px; background: var(--gold); border: none; border-radius: 10px; font-family: "Cairo", sans-serif; font-size: 17px; font-weight: 800; color: var(--white); cursor: pointer; transition: background 0.2s, transform 0.1s; margin-bottom: 14px; letter-spacing: 0.5px; }
              .btn-login:hover { background: var(--gold-dark); }
              .btn-login:active { transform: scale(0.98); }
              .or-row { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
              .or-line { flex: 1; height: 1px; background: var(--border); }
              .or-text { font-size: 12px; color: var(--text-muted); }
              .btn-file { width: 100%; height: 44px; background: var(--white); border: 1.5px solid var(--gold); border-radius: 10px; font-family: "Cairo", sans-serif; font-size: 14px; font-weight: 700; color: var(--gold); cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background 0.2s; text-decoration: none; }
              .btn-file:hover { background: #FBF6EC; }
              .btn-file svg { width: 17px; height: 17px; stroke: var(--gold); fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
              .field-hint { display: block; margin-top: 6px; font-size: 11px; line-height: 1.6; color: var(--text-muted); }
              #login_error.alert { margin-bottom: 14px; padding: 10px 14px; border-radius: 10px; font-size: 13px; border: 1px solid #f5c2c7; background: #fde8ea; color: #842029; }
              #login_error.d-none { display: none !important; }
               
              /* ── FOOTER BAR ── */
              .footer-strip {
  position: relative;
  z-index: 10;

  flex-shrink: 0;

  padding: 0 60px 18px;

  margin-top: 0;
}
              .footer-bar { margin-top:-100px; border-radius: 60px; display: flex; overflow: hidden; border: 1px solid rgba(255,255,255,0.18); }
              .footer-btn {
                flex: 1; display: flex; align-items: center; justify-content: center; gap: 10px;
                padding: 2px 10px; background: rgba(255,255,255,0.08);
                border: none; border-left: 1px solid rgba(255,255,255,0.12);
                font-family: "Cairo", sans-serif; font-size: 14px; font-weight: 600;
                color: rgba(255,255,255,0.9); cursor: pointer; direction: rtl;
                transition: background 0.2s, color 0.2s; text-decoration: none;
              }
              .footer-btn:first-child { background: rgba(255,255,255,0.05); }
              .footer-btn:last-child { border-left: none; background: rgba(255,255,255,0.05); }
              .footer-btn:hover { background: rgba(255,255,255,0.15); color: #fff; }
              .footer-btn .btn-icon { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
              .footer-btn:first-child .btn-icon { background: rgba(201,152,42,0.2); border: 1px solid rgba(201,152,42,0.4); }
              .footer-btn:last-child .btn-icon { background: rgba(201,152,42,0.2); border: 1px solid rgba(201,152,42,0.4); }
              .footer-btn.wa .btn-icon { background: rgba(37,211,102,0.15); border: 1px solid rgba(37,211,102,0.35); }
              .footer-btn svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round; }
              .footer-btn:first-child svg, .footer-btn:last-child svg { stroke: var(--gold); }
              .footer-btn.wa svg { stroke: #25D366; }
              .btn-label { display: flex; flex-direction: column; align-items: flex-end; gap: 1px; }
              .btn-label span { font-size: 14px; font-weight: 700; }
              .btn-label small { font-size: 11px; color: rgba(255,255,255,0.5); font-weight: 400; }
               
              /* ── PAGE FOOTER ── */
              .page-footer { padding: 0; direction: rtl; display: flex; flex-direction: column; align-items: center; gap: 6px; }
              .page-footer { display: none; }
              .footer-copy { font-size: 11px; color: rgba(255,255,255,0.45); text-align: center; }
              .footer-links { display: flex; gap: 24px; align-items: center; }
              .footer-links a { font-size: 11px; color: rgba(255,255,255,0.55); text-decoration: none; }
              .footer-links a:hover { color: var(--gold); }
              .footer-sep { color: rgba(255,255,255,0.25); font-size: 11px; }
               
              /* ── TABLET ── */
              @media (max-width: 960px) {
                .hero-bg img { object-position: 73% 10%; }
                .hero-body { padding: 20px 24px 14px; flex-direction: column; align-items: center; gap: 24px; }
                .hero-copy { max-width: 100%; width:100%; text-align: right; flex: none; }
                .features-row { justify-content: center; }
                .hero-title { font-size: 36px; }
                .login-card { font-family:Cairo;width: 100%; max-width: 480px; padding: 36px !important; }
                .page-footer { display: none; }
                .footer-strip { padding: 10px 24px 16px; gap: 12px; }
              }
              /* ── MOBILE ── */
              @media (max-width: 540px) {

  .hero-section {
      min-height: auto;
  }

  .hero-body {
      padding: 18px;
      gap: 18px;
  }

  .hero-bg img {
      object-position: 68% 10%;
  }

  .features-row {
      display: none;
  }

  .hero-title {
      font-size: 28px;
      margin-bottom: 0;
  }

  .hero-desc {
      display: none;
  }

  .login-card {
      padding: 36px;
      border-radius: 14px;
  }

  .card-title {
      font-size: 19px;
  }

  .footer-strip {
      padding: 0 18px 18px;
  }
}




          </style>
          
           
          <div class="hero-section">
            <div class="hero-bg">
              <img src="/web/image/577047-8ad57ce2/echo-building-4.webp" alt="ORISA Building"/>
            </div>
           
            <div class="hero-body">
              <div class="hero-copy">
                  
                <h1 class="hero-title">أوريسا خبرة تدعم  <em>نجاح مشاريعك</em></h1>
                <!--
                <div class="features-row">
                  <div class="feat">
                    <div class="feat-icon"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
                    <span class="feat-label">جودة عالية</span>
                  </div>
                  <div class="feat">
                    <div class="feat-icon"><svg viewBox="0 0 24 24"><path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/></svg></div>
                    <span class="feat-label">دعم مستمر</span>
                  </div>
                  <div class="feat">
                    <div class="feat-icon"><svg viewBox="0 0 24 24"><path d="M9 18h6M10 22h4M12 2v4M12 6a6 6 0 016 6c0 2-.8 3.8-2 5H8a7 7 0 01-2-5 6 6 0 016-6z"/></svg></div>
                    <span class="feat-label">حلول مبتكرة</span>
                  </div>
                </div>
                -->
              </div>
           
              <div class="login-card">
                <div class="card-head">
                  <h2 class="card-title">تسجيل الدخول</h2>
                  <!-- <p class="card-sub">مرحباً بك، يرجى تسجيل الدخول للمتابعة</p> -->
                </div>
                <form id="custom_login_form">
                  <div class="field">
                    <label class="field-label" for="company_id">الفرع</label>
                    <div class="input-wrap">
                      <select id="company_id" class="field-input field-select" required="required">
                        <option value="" disabled="disabled" selected="selected">اختر الفرع التابع لك</option>
                        <t t-foreach="branches" t-as="branch_name">
                          <option t-att-value="branches[branch_name]['id']">
                            <t t-esc="branch_name"/>
                          </option>
                        </t>
                      </select>
                      <span class="in-icon"><svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg></span>
                    </div>
                  </div>
                  <div class="field">
                    <label class="field-label" id="ref_label" for="ref_suffix">رقم العميل</label>
                    <div class="input-wrap">
                      <input type="text" id="ref_suffix" name="ref_suffix" class="field-input" maxlength="4" inputmode="numeric" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required="required" placeholder="* يرجى إدخال آخر 4 أرقام من رقم العميل"/>
                      <span class="in-icon"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                    </div>
                    <!-- <small class="field-hint">* يرجى إدخال آخر 4 أرقام من الرقم المرجعي الخاص و الموجود في فواتير مبيعاتك.</small> -->
                  </div>
                  <div class="field">
                    <label class="field-label" for="password">كلمة المرور</label>
                    <div class="input-wrap">
                      <input type="password" id="password" class="field-input" placeholder="أدخل كلمة المرور" required="required"/>
                      <button class="eye-btn" type="button" onclick="togglePw()" aria-label="إظهار">
                        <svg id="eye-svg" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                      </button>
                    </div>
                  </div>
                  <div class="form-meta">
                    <label class="remember"><input type="checkbox"/> تذكرني</label>
                    <a href="/reset-password" class="forgot">إعادة تعيين كلمة المرور</a>
                  </div>
                  <button class="btn-login" type="submit">دخول</button>
                 <div id="login_error" class="alert alert-danger d-none">
</div>
                  <div class="or-row"><div class="or-line"/><span class="or-text">أو</span><div class="or-line"/></div>
                  <a href="/account/request" class="btn-file">
                    <svg viewBox="0 0 24 24"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
                    فتح ملف جديد
                  </a>
                </form>
              </div>
            </div>
           
            <div class="footer-strip">
              <div class="footer-bar">
                <a href="tel:+966920000136" class="footer-btn">
                  <div class="btn-icon"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg></div>
                  <div class="btn-label"><span>اتصال</span><small>تواصل معنا مباشرة</small></div>
                </a>
                <a href="https://wa.me/966920000136" class="footer-btn wa" target="_blank" rel="noopener noreferrer">
                  <div class="btn-icon"><svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg></div>
                  <div class="btn-label"><span>واتساب</span><small>راسلنا على واتساب</small></div>
                </a>
                <a href="/" class="footer-btn">
                  <div class="btn-icon"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
                  <div class="btn-label"><span>دخول كزائر</span><small>تصفح بدون حساب</small></div>
                </a>
              </div>
              <footer class="page-footer">
                <p class="footer-copy">جميع الحقوق محفوظة لشركة Echo Emaar Trading Company</p>
                <div class="footer-links">
                  <a href="#">سياسة الخصوصية</a>
                  <span class="footer-sep">|</span>
                  <a href="#">الشروط والأحكام</a>
                </div>
              </footer>
            </div>
          </div>
           
          <script>
          function togglePw() {
            var inp = document.getElementById("password");
            var ico = document.getElementById("eye-svg");
            if (inp.type === "password") {
              inp.type = "text";
              ico.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
            } else {
              inp.type = "password";
              ico.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
            }
          }
          </script>

      </div>
  </t>
</t>