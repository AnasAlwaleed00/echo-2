<t t-name="portal_customer_statement_range.customer_statement_portal_template">
    <t t-call="website.layout">

        <div class="container my-5" style="direction:rtl;font-family:Cairo,Arial,sans-serif;">

            <!-- عنوان الصفحة -->
            <div class="text-center mb-4">
                <h2 class="fw-bold">كشف حساب العميل</h2>
                <div class="text-muted mt-2">
                    <strong>الشركة:</strong>
                    <t t-esc="company.name"/>
                </div>
            </div>

            <!-- نموذج البحث -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">

                    <form method="get" action="/my/customer_statement">

                        <div class="row g-3">

                            <div class="col-md-4">
                                <label class="form-label fw-bold">
                                    من تاريخ
                                </label>

                                <input type="date" name="date_from" t-att-value="date_from or ''" required="required" class="form-control"/>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">
                                    إلى تاريخ
                                </label>

                                <input type="date" name="date_to" t-att-value="date_to or ''" required="required" class="form-control"/>
                            </div>

                            <div class="col-md-4 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100">
                                    عرض كشف الحساب
                                </button>
                            </div>

                        </div>

                    </form>

                </div>
            </div>

            <!-- النتائج -->
            <t t-if="lines">

                <div class="card shadow-sm border-0">

                    <div class="card-header bg-light">

                        <div class="row">

                            <div class="col-md-6">
                                <strong>الفترة:</strong>
                                <t t-esc="date_from"/>
                                -
                                <t t-esc="date_to"/>
                            </div>

                            <div class="col-md-6 text-end">
                                <strong>عدد الحركات:</strong>
                                <t t-esc="len(lines)"/>
                            </div>

                        </div>

                    </div>

                    <div class="card-body p-0">

                        <div class="table-responsive">

                            <table class="table table-hover table-striped mb-0">

                                <thead class="table-dark">

                                    <tr>
                                        <th>التاريخ</th>
                                        <!--<th>رقم القيد</th>-->
                                        <th>الوصف</th>
                                        <th class="text-start">مدين</th>
                                        <th class="text-start">دائن</th>
                                        <th class="text-start">الرصيد</th>
                                    </tr>

                                </thead>

                                <tbody>

                                    <t t-set="balance" t-value="0"/>

                                    <t t-foreach="lines" t-as="line">

                                        <tr>

                                            <td>
                                                <t t-esc="line.date"/>
                                            </td>

                                            <!--<td>-->
                                            <!--    <t t-esc="line.move_id.name or line.move_id.ref"/>-->
                                            <!--</td>-->

                                            <td>
                                                <t t-esc="line.name or line.ref or ''"/>
                                            </td>

                                            <td class="text-start">
                                                <t t-esc="'{:,.2f}'.format(line.debit or 0.0)"/>
                                            </td>

                                            <td class="text-start">
                                                <t t-esc="'{:,.2f}'.format(line.credit or 0.0)"/>
                                            </td>

                                            <td class="text-start">

                                                <t t-set="balance" t-value="balance + (line.debit - line.credit)"/>

                                                <strong>
                                                    <t t-esc="'{:,.2f}'.format(balance)"/>
                                                </strong>

                                            </td>

                                        </tr>

                                    </t>

                                </tbody>

                            </table>

                        </div>

                    </div>

                </div>

                <!-- الرصيد الختامي -->
                <div class="mt-4">

                    <div class="alert alert-success d-flex justify-content-between align-items-center">

                        <span class="fw-bold fs-5">
                            الرصيد الختامي
                        </span>

                        <span class="fw-bold fs-4">
                            <t t-esc="'{:,.2f}'.format(balance)"/>
                        </span>

                    </div>

                </div>

                <!-- زر PDF -->
                <!--<t t-if="date_from and date_to">-->

                <!--    <div class="text-center mt-3">-->

                <!--        <a t-attf-href="/my/customer_statement/export_pdf?date_from={{date_from}}&amp;date_to={{date_to}}"-->
                <!--           class="btn btn-danger btn-lg">-->

                <!--            <i class="fa fa-file-pdf-o me-2"/>-->

                <!--            تحميل كشف الحساب PDF-->

                <!--        </a>-->

                <!--    </div>-->

                <!--</t>-->

            </t>

        </div>

    </t>
</t>