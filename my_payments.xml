<t name="Partner Payments Page" t-name="partner_website_registration.portal_partner_payments_page">
    <t t-call="portal.portal_layout">

        <div class="container o_portal_wrap" style="direction: rtl; text-align: right;">

            <div class="o_portal_my_doc_title">
                <h3 class="fw-bold">سندات القبض الخاصة بي</h3>
            </div>

            <table class="table table-striped table-bordered mt-4" id="paymentsTable">
                <thead class="table-light">
                    <tr>
                      
                        <th>التاريخ</th>
                        <th>'طريقة السداد</th>
                        <th>المبلغ</th>
                        <th>الحالة</th>
                        <th>إجراء</th>
                    </tr>
                </thead>

                <tbody>

                    <!-- لا توجد سندات -->
                    <t t-if="not payments or len(payments) == 0">
                        <tr>
                            <td colspan="7" class="text-center text-muted">لا توجد سندات حتى الآن</td>
                        </tr>
                    </t>

                    <!-- تكرار السندات -->
                    <t t-foreach="payments" t-as="p">
                        <tr>

                            
                            <td><t t-esc="p['date']"/></td>
                            <td>
<t t-if="p.get('journal_type') == 'cash'">
    نقدي
</t>
<t t-else="">
    <t t-esc="p.get('journal_name')"/>
</t>
</td>
                         

                            <td><b><t t-esc="p['amount']"/></b></td>

                            <!-- حالة السند مع التلوين -->
                         <td>
<t t-if="p.get('state_key') == 'posted'">
    <span class="badge" style="background:#28a745;color:#fff;padding:6px 10px;">
        مؤكد
    </span>
</t>

<t t-elif="p.get('state_key') == 'review'">
    <span class="badge" style="background:#007bff;color:#fff;padding:6px 10px;">
        قيد المراجعة
    </span>
</t>

<t t-elif="p.get('state_key') == 'waiting_attachment'">
    <span class="badge" style="background:#ff9800;color:#000;padding:6px 10px;">
        في انتظار رفع المستند
    </span>
</t>

<t t-else="">
    <span class="text-muted">—</span>
</t>
</td>



                            <!-- عمود إجراء -->
                      <td>
<t t-if="p.get('show_upload')">
<a t-att-href="'/my/upload_payment_attachment/%s' % p['id']" class="btn btn-sm btn-warning">
    رفع المستند
</a>
</t>


</td>




                        </tr>
                    </t>

                </tbody>
            </table>

        </div>

    </t>
</t>