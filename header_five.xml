<data inherit_id="website.layout" name="Header Five - Hide on Scroll (COMPLETE)" active="False">

    <xpath expr="//header" position="attributes">
        <attribute name="t-attf-class" add="biz-emart-shop-header" separator=" "/>
    </xpath>
    
    <!-- Add CSS -->
    <xpath expr="//head" position="inside">
        <style>
            /* Header Hide on Scroll - Fixed positioning */
            .js-mobile-header {
                position: fixed !important;
                top: 0;
                left: 0;
                right: 0;
                z-index: 1000;
                transition: transform 0.3s ease, opacity 0.3s ease;
                will-change: transform, opacity;
                background: white;
            }
            
            .js-mobile-header.hide-on-scroll {
                transform: translateY(-100%);
                opacity: 0;
                pointer-events: none;
            }
            
            /* Add spacer element for fixed header - this ensures content isn't hidden */
            .header-spacer {
                height: 0;
                transition: height 0.25s ease;

            }
        </style>
    </xpath>
    
    <!-- Add JavaScript -->
    <xpath expr="//body" position="inside">
        
        <script type="text/javascript">
            (function() {
                'use strict';
                
                let header = null;
                let scrollTimer = null;
                let scrollContainer = null;
                let headerSpacer = null;
                
                function findScrollContainer() {
                    const possibleContainers = [
                        document.documentElement,
                        document.body,
                        document.getElementById('wrapwrap'),
                        document.getElementById('wrap'),
                        document.querySelector('.o_main'),
                        document.querySelector('main')
                    ];
                    
                    for (let container of possibleContainers) {
                        if (container &amp;&amp; container.scrollHeight &gt; container.clientHeight) {
                            console.log('✓ Found scrolling container:', container.tagName, container.id || container.className);
                            return container;
                        }
                    }
                    
                    console.log('Using window as scroll container');
                    return window;
                }
                
                function createHeaderSpacer() {
                    // Create a spacer div that takes up the space of the fixed header
                    headerSpacer = document.createElement('div');
                    headerSpacer.className = 'header-spacer';
                    
                    // Insert spacer right after the header
                    if (header.parentNode) {
                        header.parentNode.insertBefore(headerSpacer, header.nextSibling);
                        console.log('✓ Header spacer created');
                    }
                }
                
                function updateHeaderSpacing() {
                    // Get the actual height of the header
                    const headerHeight = header.offsetHeight;
                    console.log('Header height:', headerHeight + 'px');
                    
                    // Set the spacer to match header height
                    if (headerSpacer) {
                        headerSpacer.style.height = headerHeight + 'px';
                        console.log('✓ Spacer height set to:', headerHeight + 'px');
                    }
                }
                
                function init() {
                    setTimeout(function() {
                        header = document.querySelector('.js-mobile-header');
                        
                        if (!header) {
                            console.error('❌ Header not found!');
                            return;
                        }
                        
                        console.log('✓ Header found');
                        
                        // Create spacer element
                        createHeaderSpacer();
                        
                        // Set initial spacing
                        updateHeaderSpacing();
                        
                        // Update spacing on window resize (in case header height changes)
                        window.addEventListener('resize', updateHeaderSpacing);
                        
                        // Find and attach to scrolling container
                        scrollContainer = findScrollContainer();
                        attachScrollListener();
                        
                        console.log('✓ Header hide-on-scroll initialized successfully');
                    }, 200);
                }
                
               function attachScrollListener() {
                    scrollContainer.addEventListener('scroll', function () {

                        // Hide header
                        header.classList.add('hide-on-scroll');

                        // 🔥 Collapse spacer
                        if (headerSpacer) {
                            headerSpacer.style.height = '0px';
                        }

                        if (scrollTimer) {
                            clearTimeout(scrollTimer);
                        }

                        scrollTimer = setTimeout(function () {

                            // Show header again
                            header.classList.remove('hide-on-scroll');

                            // 🔥 Restore spacer height
                            updateHeaderSpacing();

                        }, 250);

                    }, { passive: true });
                }
                
                // Initialize
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', init);
                } else {
                    init();
                }
            })();
        </script>
    </xpath>
    
