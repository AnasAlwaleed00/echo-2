<t name="Quick View Details" t-name="theme_emart_plant.get_product_qv_details_template">
    <style>
        /* Mobile */
        @media (max-width: 767px) {
            .preview-price-details-container {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 8px;
            }
        }
        /* Tablet */
        @media (min-width: 768px) and (max-width: 1024px) {
            .preview-price-details-container {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 8px;
            }
        }
    </style>

    <t t-if="product">
        <t t-set="combination" t-value="product._get_first_possible_combination()"/>
        <t t-set="combination_info" t-value="product._get_combination_info(combination, add_qty=add_qty or 1)"/>
        <t t-set="product_variant" t-value="product.env['product.product'].browse(combination_info['product_id'])"/>

        <div class="quick-modal-backdrop"/>
        <t t-set="store_time" t-value="website.store_timing()"/>
        
        <div class="quick-modal">
            <div itemscope="itemscope" itemtype="http://schema.org/Product" class="js_sale quick-popout">
                <a href="#" class="quick_close">
                    <i class="ri ri-close-line align-middle text-dark"/>
                </a>
                
                <div class="container oe_website_sale" id="product_detail">
                    <div id="product_detail_main" class="row justify-content-center" t-att-data-image_width="website.product_page_image_width" t-att-data-image_layout="website.product_page_image_layout">
                        
                        <h1 itemprop="name" t-field="product.web_pro_name">Product Name</h1>
                        
                        <div class="col-md-12 col-xl-5 product-img-section">
                            <div class="product-img-box o_wsale_product_images">
                                <t t-call="website_sale.shop_product_images"/>
                            </div>
                        </div>
                        
                        <div class="col-md-12 col-xl-7 quick_modal_product_details" id="product_details">
                            <span itemprop="url" style="display:none;" t-out="product.website_url"/>
                            
                            <form t-if="product._is_add_to_cart_possible()" action="/shop/cart/update" method="POST">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                
                                <div class="js_product js_main_product pt16">
                                    <div class="product-name-share pb16 align-items-center">
                                        <t t-if="product.web_pro_name">
                                            <h1 itemprop="name" t-field="product.web_pro_name">Product Name</h1>
                                        </t>
                                        <t t-else=" ">
                                            <h1 itemprop="name" t-field="product.name">Product Name</h1>
                                        </t>
                                        
                                        <div class="preview-price-details-container">
                                            <t t-call="website_sale.product_price"/>
                                            <a t-att-href="'/shop/%s' % slug(product)" class="view-detail text-decoration-none">
                                                مشاهدة التفاصيل
                                                <span class="ri ri-arrow-right-line align-middle"/>
                                            </a>
                                        </div>
                                    </div>
                                    
                                    <t t-placeholder="select">
                                        <input type="hidden" class="product_id" name="product_id" t-att-value="product_variant.id"/>
                                        <input type="hidden" class="product_template_id" name="product_template_id" t-att-value="product.id"/>
                                        <t t-if="combination" t-call="website_sale.variants">
                                            <t t-set="ul_class" t-value="'flex-column'"/>
                                            <t t-set="parent_combination" t-value="None"/>
                                        </t>
                                        <t t-else="">
                                            <ul class="d-none js_add_cart_variants mt-3" t-att-data-attribute_exclusions="{'exclusions: []'}"/>
                                        </t>
                                    </t>
                                    
                                    <p t-if="True" class="css_not_available_msg alert alert-warning">This combination does not exist.</p>
                                    
                                    <!-- الحاوية السليمة للأزرار وعداد الكمية -->
                                    <div id="o_wsale_cta_wrapper" class="d-flex align-items-center flex-wrap">
                                        <div id="add_to_cart_wrap" t-attf-class="{{'d-none' if combination_info['prevent_zero_price_sale'] else 'd-inline-flex'}} align-items-center w-100 w-xl-auto mt-3 mt-xl-0">
                                            
                                            <div class="css_quantity input-group me-2" style="max-width: 130px;">
                                                <a t-attf-href="#" class="btn btn-link js_add_cart_json border-end-0 shadow-none" aria-label="Remove one" title="Remove one">
                                                    <i class="fa fa-minus"/>
                                                </a>
                                                <input type="text" class="form-control quantity text-center js_quantity border-start-0 border-end-0 shadow-none" data-min="1" name="add_qty" t-att-value="add_qty or 1"/>
                                                <a t-attf-href="#" class="btn btn-link float_left js_add_cart_json border-start-0 shadow-none" aria-label="Add one" title="Add one">
                                                    <i class="fa fa-plus"/>
                                                </a>
                                            </div>

                                           <div class="ajax_cart_modal_tools ms-2 me-2">
    <!-- 1. حالة الزائر (غير مسجل الدخول) -->
    <t t-if="request.env.user._is_public()">
        <a role="button" class="btn btn-md btn-cart btn-primary fw-bold two w-100" href="/custom/login" onclick="alert('يرجى تسجيل الدخول أولاً لتتمكن من إضافة المنتجات للسلة.');">
            <span class="ri ri-shopping-bag-2-line me-2 align-middle"/>
            <span class="align-middle">اضافة للسلة</span>
        </a>
    </t>
    
    <!-- 2. حالة العميل (مسجل الدخول) -->
    <t t-else="">
        <a role="button" class="btn btn-md btn-cart btn-primary a-submit-btn ajax-cart-btn js_check_product fw-bold two w-100" href="#">
            <span class="ri ri-shopping-bag-2-line me-2 align-middle"/>
            <span class="align-middle">اضافة للسلة</span>
        </a>
    </t>
</div>

                                            <t t-if="is_view_active('website_sale.product_buy_now')">
                                                <t t-if="website.timings">
                                                    <t t-if="store_time['store'] == True">
                                                        <t t-if="uid and uid &gt; 0">
                                                            <a role="button" t-attf-class="btn btn-secondary btn-lg o_we_buy_now sticky_cart_button d-block d-sm-inline-block mt-3 mt-md-0" href="#">
                                                                <span class="ri ri-share-forward-line align-middle me-2 text-white"/>
                                                                <span>شراء الان</span>
                                                            </a>
                                                        </t>
                                                        <t t-else="">
                                                            <t t-if="website.prevent_guest_checkout">
                                                                <t t-if="request.website.viewref('theme_emart_plant.loginsignup_popup_bizt').active">
                                                                    <a role="button" t-attf-class="btn btn-secondary btn-lg openpop buy_now_login sticky_cart_button d-block d-sm-inline-block mt-3 mt-md-0" href="#" data-bs-toggle="modal" data-bs-target="#popupuserlogin" t-att-data-theme_name="request.website.sudo().theme_id.name">
                                                                        <span class="ri ri-share-forward-line align-middle me-2 text-white"/>
                                                                        <span>شراء الان</span>
                                                                    </a>
                                                                </t>
                                                                <t t-else="">
                                                                    <a role="button" t-attf-class="btn btn-secondary btn-lg buy_now_login sticky_cart_button d-block d-sm-inline-block mt-3 mt-md-0" href="/web/login">
                                                                        <span class="ri ri-share-forward-line align-middle me-2 text-white"/>
                                                                        <span>BUY NOW</span>
                                                                    </a>
                                                                </t>
                                                            </t>
                                                            <t t-else="">
                                                                <a role="button" t-attf-class="btn btn-secondary btn-lg o_we_buy_now sticky_cart_button d-block d-sm-inline-block mt-3 mt-md-0" href="#">
                                                                    <span class="ri ri-share-forward-line align-middle me-2 text-white"/>
                                                                    <span>BUY NOW</span>
                                                                </a>
                                                            </t>
                                                        </t>
                                                    </t>
                                                    <t t-else="">
                                                        <div class="alert alert-warning text-center mt16">
                                                            <span class="d-flex flex-column">
                                                                <strong>Store Closed</strong>
                                                                <span>
                                                                    Please Visit Between <t t-out="store_time['opening_time']"/>
                                                                    to <t t-out="store_time['closing_time']"/>
                                                                </span>
                                                            </span>
                                                        </div>
                                                    </t>
                                                </t>
                                                <t t-else="">
                                                    <t t-if="uid and uid &gt; 0">
                                                        <a role="button" t-attf-class="btn btn-secondary btn-lg o_we_buy_now sticky_cart_button d-block d-sm-inline-block mt-3 mt-md-0" href="#">
                                                            <span class="ri ri-share-forward-line align-middle me-2 text-white"/>
                                                            <span>BUY NOW</span>
                                                        </a>
                                                    </t>
                                                    <t t-else="">
                                                        <t t-if="website.prevent_guest_checkout">
                                                            <t t-if="request.website.viewref('theme_emart_plant.loginsignup_popup_bizt').active">
                                                                <a role="button" t-attf-class="btn btn-secondary btn-lg openpop buy_now_login sticky_cart_button d-block d-sm-inline-block mt-3 mt-md-0" href="#" data-bs-toggle="modal" data-bs-target="#popupuserlogin" t-att-data-theme_name="request.website.sudo().theme_id.name">
                                                                    <span class="ri ri-share-forward-line align-middle me-2 text-white"/>
                                                                    <span>BUY NOW</span>
                                                                </a>
                                                            </t>
                                                            <t t-else="">
                                                                <a role="button" t-attf-class="btn btn-secondary btn-lg buy_now_login sticky_cart_button d-block d-sm-inline-block mt-3 mt-md-0" href="/web/login">
                                                                    <span class="ri ri-share-forward-line align-middle me-2 text-white"/>
                                                                    <span>BUY NOW</span>
                                                                </a>
                                                            </t>
                                                        </t>
                                                        <t t-else="">
                                                            <a role="button" t-attf-class="btn btn-secondary btn-lg o_we_buy_now sticky_cart_button d-block d-sm-inline-block mt-3 mt-md-0" href="#">
                                                                <span class="ri ri-share-forward-line align-middle me-2 text-white"/>
                                                                <span>BUY NOW</span>
                                                            </a>
                                                        </t>
                                                    </t>
                                                </t>
                                            </t>
                                        </div>
                                        
                                        <div class="biz-compare-button">
                                            <a type="button" role="button" class="btn btn-default o_add_wishlist ms-1" t-att-disabled="in_wish or None" title="Add to Wishlist" t-att-data-product-product-id="product.product_variant_ids[0].id if product.product_variant_ids else '0'" data-action="o_wishlist">
                                                <span class="ri ri-heart-line" role="img" aria-label="Add to wishlist"/>
                                            </a>
                                            <t t-set="product_variant_id" t-value="product._get_first_possible_variant_id()"/>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="availability_messages o_not_editable"/>
                                <t t-nocache="The wishlist depends on the user and must not be shared with other users. The product come from the controller.">
                                    <t t-set="product_variant" t-value="product_variant or product._create_first_product_variant()"/>
                                    <t t-set="in_wish" t-value="product_variant and product_variant._is_in_wishlist()"/>
                                    <button t-if="product_variant" type="button" role="button" class="btn btn-link px-0 pe-3 o_add_wishlist_dyn d-none" t-att-disabled="in_wish or None" t-att-data-product-template-id="product.id" t-att-data-product-product-id="product_variant.id" data-action="o_wishlist" title="Add to wishlist">
                                        <i class="fa fa-heart-o me-2" role="img" aria-label="Add to wishlist"/>Add to wishlist
                                    </button>
                                </t>
                                
                                <div id="contact_us_wrapper" t-attf-class="{{'d-flex' if combination_info['prevent_zero_price_sale'] else 'd-none'}} oe_structure oe_structure_solo #{_div_classes}">
                                    <section class="s_text_block" data-snippet="s_text_block" data-name="Text">
                                        <div class="container">
                                            <a t-att-href="website.contact_us_button_url" class="btn btn-primary btn_cta">
                                                Contact Us
                                            </a>
                                        </div>
                                    </section>
                                </div>
                            </form>
                            
                            <p t-elif="not product.active" class="alert alert-warning">This product is no longer available.</p>
                            <p t-else="" class="alert alert-warning">This product has no valid combination.</p>
                            
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
    
    <t t-if="error">
        <div class="quick-modal-backdrop"/>
        <div class="quick-modal">
            <div class="quick-popout">
                <button class="quick_close">
                    <i class="lnr lnr-cross"/>
                </button>
                <div class="alert alert-warning m-4" t-out="error"/>
            </div>
        </div>
    </t>
</t>