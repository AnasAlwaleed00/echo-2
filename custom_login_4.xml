          <script>
          <![CDATA[
            var ECHO_LOGIN_STORAGE_KEY = "echo_login_remember";

            function togglePw() {
              var inp = document.getElementById("password");
              var ico = document.getElementById("eye-svg");
              if (inp.type === "password") {
                inp.type = "text";
                ico.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
              } else {
                inp.type = "password";
                ico.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
              }
            }

            function saveRememberMe() {
              var remember = document.getElementById("remember_me");
              var company = document.getElementById("company_id");
              var refSuffix = document.getElementById("ref_suffix");
              if (!remember || !company || !refSuffix) return;

              if (remember.checked) {
                localStorage.setItem(ECHO_LOGIN_STORAGE_KEY, JSON.stringify({
                  company_id: company.value,
                  ref_suffix: refSuffix.value
                }));
              } else {
                localStorage.removeItem(ECHO_LOGIN_STORAGE_KEY);
              }
            }

            function restoreRememberMe() {
              var raw = localStorage.getItem(ECHO_LOGIN_STORAGE_KEY);
              if (!raw) return;

              try {
                var saved = JSON.parse(raw);
                var company = document.getElementById("company_id");
                var refSuffix = document.getElementById("ref_suffix");
                var remember = document.getElementById("remember_me");
                if (!company || !refSuffix || !remember) return;

                if (saved.company_id && company.querySelector('option[value="' + saved.company_id + '"]')) {
                  company.value = saved.company_id;
                }
                if (saved.ref_suffix) {
                  refSuffix.value = saved.ref_suffix;
                }
                remember.checked = true;
                company.dispatchEvent(new Event("change", { bubbles: true }));
              } catch (e) {
                localStorage.removeItem(ECHO_LOGIN_STORAGE_KEY);
              }
            }

            document.addEventListener("DOMContentLoaded", function () {
              restoreRememberMe();

              var form = document.getElementById("custom_login_form");
              if (form) {
                form.addEventListener("submit", saveRememberMe);
              }
            });
          ]]>
          </script>
    
