<t name="My Sales Orders" t-name="sale.portal_my_orders">
    <t t-call="portal.portal_layout">
        <t t-set="breadcrumbs_searchbar" t-value="True"/>
        <t t-call="portal.portal_searchbar">
            <t t-set="title">طلباتي</t>
        </t>

        <div class="o_portal_wrap">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

                <!-- Page Header -->
                <div class="flex items-center justify-between mb-5">
                    <div>
                        <h1 class="text-xl sm:text-2xl font-bold text-gray-900">طلباتي</h1>
                        <p class="text-xs sm:text-sm text-gray-500 mt-0.5">تتبع حالة طلباتك وتفاصيل الشحن</p>
                    </div>
                    <t t-if="orders">
                        <span class="inline-flex items-center gap-1.5 bg-blue-50 text-blue-700 text-xs sm:text-sm font-medium px-2.5 py-1 rounded-full border border-blue-100">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M16 10a4 4 0 0 1-8 0"/>
                                <path d="M3.103 6.034h17.794"/>
                                <path d="M3.4 5.467a2 2 0 0 0-.4 1.2V20a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6.667a2 2 0 0 0-.4-1.2l-2-2.667A2 2 0 0 0 17 2H7a2 2 0 0 0-1.6.8z"/>
                            </svg>
                            <t t-out="len(orders)"/>
                            طلب
                        </span>
                    </t>
                </div>

                <!-- Empty State -->
                <t t-if="not orders">
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm flex flex-col items-center justify-center py-20 px-6 text-center">
                        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M16 10a4 4 0 0 1-8 0"/>
                                <path d="M3.103 6.034h17.794"/>
                                <path d="M3.4 5.467a2 2 0 0 0-.4 1.2V20a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6.667a2 2 0 0 0-.4-1.2l-2-2.667A2 2 0 0 0 17 2H7a2 2 0 0 0-1.6.8z"/>
                            </svg>
                        </div>
                        <h3 class="text-base font-semibold text-gray-800 mb-1">لا توجد طلبات بعد</h3>
                        <p class="text-sm text-gray-500 max-w-xs">لم يتم تسجيل أي طلبات لحسابك حتى الآن. ستظهر طلباتك هنا فور إنشائها.</p>
                    </div>
                </t>
<!-- الحسابات البرمجية الدقيقة بناءً على فلاتر النظام -->
<t t-set="total_orders" t-value="len(orders)"/>
<t t-set="under_pricing_orders" t-value="len(orders.filtered(lambda o: o.state == 'draft' and o.price_state == 'price_not_set'))"/>
<t t-set="priced_orders" t-value="len(orders.filtered(lambda o: o.state == 'draft' and o.price_state == 'price_set'))"/>
<t t-set="confirmed_orders" t-value="len(orders.filtered(lambda o: o.state == 'sale'))"/>

<div class="grid grid-cols-2 lg:grid-cols-4 gap-2 sm:gap-3 mb-5" dir="rtl">

    <!-- 1. إجمالي الطلبات -->
    <div class="bg-white rounded-xl p-2.5 sm:p-3 border border-purple-100 shadow-sm hover:shadow-md hover:border-purple-200 transition-all duration-200 flex items-center gap-2 sm:gap-2.5">
        <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg bg-gradient-to-br from-purple-100 to-indigo-100 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 10a4 4 0 0 1-8 0"/>
                <path d="M3.103 6.034h17.794"/>
                <path d="M3.4 5.467a2 2 0 0 0-.4 1.2V20a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6.667a2 2 0 0 0-.4-1.2l-2-2.667A2 2 0 0 0 17 2H7a2 2 0 0 0-1.6.8z"/>
            </svg>
        </div>
        <div class="min-w-0 flex-1">
            <div class="text-[10px] sm:text-xs font-medium text-purple-600 leading-tight truncate">إجمالي الطلبات</div>
            <div class="text-lg sm:text-xl font-bold text-purple-900 leading-tight mt-0.5">
                <t t-out="total_orders"/>
            </div>
        </div>
    </div>

    <!-- 2. قيد التسعير -->
    <div class="bg-white rounded-xl p-2.5 sm:p-3 border border-orange-100 shadow-sm hover:shadow-md hover:border-orange-200 transition-all duration-200 flex items-center gap-2 sm:gap-2.5">
        <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg bg-gradient-to-br from-orange-100 to-amber-100 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
            </svg>
        </div>
        <div class="min-w-0 flex-1">
            <div class="text-[10px] sm:text-xs font-medium text-orange-600 leading-tight truncate">قيد التسعير</div>
            <div class="text-lg sm:text-xl font-bold text-orange-900 leading-tight mt-0.5">
                <t t-out="under_pricing_orders"/>
            </div>
        </div>
    </div>

    <!-- 3. تم التسعير -->
    <div class="bg-white rounded-xl p-2.5 sm:p-3 border border-blue-100 shadow-sm hover:shadow-md hover:border-blue-200 transition-all duration-200 flex items-center gap-2 sm:gap-2.5">
        <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg bg-gradient-to-br from-blue-100 to-cyan-100 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
        </div>
        <div class="min-w-0 flex-1">
            <div class="text-[10px] sm:text-xs font-medium text-blue-600 leading-tight truncate">تم التسعير</div>
            <div class="text-lg sm:text-xl font-bold text-blue-900 leading-tight mt-0.5">
                <t t-out="priced_orders"/>
            </div>
        </div>
    </div>

    <!-- 4. الطلبات المؤكدة -->
    <div class="bg-white rounded-xl p-2.5 sm:p-3 border border-green-100 shadow-sm hover:shadow-md hover:border-green-200 transition-all duration-200 flex items-center gap-2 sm:gap-2.5">
        <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg bg-gradient-to-br from-green-100 to-emerald-100 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
        </div>
        <div class="min-w-0 flex-1">
            <div class="text-[10px] sm:text-xs font-medium text-green-600 leading-tight truncate">الطلبات المؤكدة</div>
            <div class="text-lg sm:text-xl font-bold text-green-900 leading-tight mt-0.5">
                <t t-out="confirmed_orders"/>
            </div>
        </div>
    </div>

</div>
                <!-- Orders Table -->
                <t t-if="orders">
                    <div class="md:bg-white md:rounded-2xl md:shadow-sm md:border md:border-gray-200 overflow-hidden">

                        <!-- Desktop Table -->
                        <div class="hidden md:block overflow-x-auto">
                            <table class="w-full">
                                <thead>
                                    <tr class="bg-gray-50 border-b border-gray-200">
                                        <th class="px-6 py-3.5 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">رقم الطلب</th>
                                        <th class="px-6 py-3.5 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">التاريخ</th>
                                        <th class="px-6 py-3.5 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">الحالة</th>
                                        <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">الإجمالي</th>
                                        <th class="px-6 py-3.5"/>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    <t t-foreach="orders" t-as="order">
                                        <tr class="hover:bg-gray-50 transition-colors duration-150 group">

                                            <!-- Order Number -->
                                            <td class="px-6 py-4">
                                                <a t-att-href="order.get_portal_url()" class="font-semibold text-blue-600 hover:text-blue-800 hover:underline text-sm">
                                                    <t t-out="order.name"/>
                                                </a>
                                            </td>

                                            <!-- Date -->
                                            <td class="px-6 py-4">
                                                <div class="text-sm text-gray-700">
                                                    <span t-field="order.date_order" t-options="{'widget': 'date'}"/>
                                                </div>
                                                <div class="text-xs text-gray-400 mt-0.5">
                                                    <span t-field="order.date_order" t-options="{'time_only': True}"/>
                                                </div>
                                            </td>

                                            <!-- Status -->
                                            <td class="px-6 py-4 text-center">
                                               <t t-if="order.state == 'sale'">
    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-100">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500"/>
        مؤكد
    </span>
</t>

<t t-elif="order.state == 'draft' and order.price_state != 'price_set'">
<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-orange-50 text-orange-700 border border-orange-100">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"/>
        قيد التسعير
    </span>
</t>

<t t-elif="order.state == 'draft' and order.price_state == 'price_set'">
    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-100">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-500"/>
        تم التسعير
    </span>
</t>
                                            </td>

                                            <!-- Total -->
                                            <td class="px-6 py-4 text-left">
                                                <t t-if="order.state in ('sale','done') or order.price_state == 'price_set'">
                                                    <span class="font-semibold text-gray-900 text-sm" t-field="order.amount_total"/>
                                                </t>
                                                <t t-else="">
                                                    <span class="text-xs text-gray-400 italic">بعد التسعير</span>
                                                </t>
                                            </td>

                                            <!-- View Arrow -->
                                            <td class="px-4 py-4 text-right">
                                                <a t-att-href="order.get_portal_url()" class="text-gray-300 group-hover:text-blue-500 transition-colors duration-150">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <path d="m15 18-6-6 6-6"/>
                                                    </svg>
                                                </a>
                                            </td>

                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <!-- Mobile Cards -->
                        <!-- Mobile & Tablet Cards -->
<div class="lg:hidden flex flex-col gap-3">

    <t t-foreach="orders" t-as="order">

        <a t-att-href="order.get_portal_url()" class="group bg-white rounded-2xl p-4 shadow-sm hover:shadow-md hover:bg-blue-50 transition-all duration-200">

            <div class="flex items-center gap-3">

                <!-- Icon -->
                <div class="w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2">
                        <path d="M16 10a4 4 0 0 1-8 0"/>
                        <path d="M3.103 6.034h17.794"/>
                        <path d="M3.4 5.467a2 2 0 0 0-.4 1.2V20a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6.667a2 2 0 0 0-.4-1.2l-2-2.667A2 2 0 0 0 17 2H7a2 2 0 0 0-1.6.8z"/>
                    </svg>
                </div>

                <!-- Content -->
                <div class="flex-1 min-w-0">

                    <!-- Order Name -->
                    <div class="font-bold text-blue-600 text-base truncate">
                        <t t-out="order.name"/>
                    </div>

                    <!-- Date -->
                    <div class="flex items-center gap-1 text-gray-400 text-sm mt-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect width="18" height="18" x="3" y="4" rx="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/>
                            <line x1="8" y1="2" x2="8" y2="6"/>
                            <line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>

                        <span t-field="order.date_order" t-options="{'widget':'date'}"/>
                    </div>

                </div>

                <!-- Arrow -->
                <div class="text-gray-300 group-hover:text-blue-500">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m15 18-6-6 6-6"/>
                    </svg>
                </div>

            </div>

            <!-- Bottom Row -->
            <div class="mt-4 flex items-center justify-between">

    <!-- Status -->
    <div class="text-center">
        <div class="text-[10px] text-gray-400 mb-1 font-medium">
            الحالة
        </div>

        <t t-if="order.state == 'sale'">
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-lg text-xs font-semibold bg-green-100 text-green-700">
                ✓ الطلبات المؤكدة
            </span>
        </t>

        <t t-elif="order.state == 'draft' and order.price_state != 'price_set'">
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-lg text-xs font-semibold bg-orange-100 text-orange-700">
                ⏱ قيد التسعير
            </span>
        </t>

        <t t-elif="order.state == 'draft' and order.price_state == 'price_set'">
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-lg text-xs font-semibold bg-blue-100 text-blue-700">
                💰 تم التسعير
            </span>
        </t>
    </div>

    <!-- Amount -->
    <div class="text-center">
        <div class="text-[10px] text-gray-400 mb-1 font-medium">
            الإجمالي
        </div>

        <t t-if="order.state in ('sale','done') or order.price_state == 'price_set'">
            <span class="text-lg font-bold text-gray-900" t-field="order.amount_total"/>
        </t>

        <t t-else="">
            <span class="text-sm text-gray-400">
                بعد التسعير
            </span>
        </t>
    </div>

</div>

        </a>

    </t>

</div>
                    </div>
                </t>

            </div>
        </div>
    </t>
</t>