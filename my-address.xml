<t t-name="theme_emart_plant.address_list">
    <t t-call="website.layout">
        <t t-set="additional_title">تفاصيل العنوان</t>
        <div id="wrap">
            <section class="cart_banner_extra pt32 o_colored_level" data-name="Title" style="background-image: none;">
                <section class="pt32 o_colored_level" data-name="Title" style="background-image: none;" data-tilt-feature="">
                    <div class="container">
                        <div class="cart_banner_description text-center">
                            <h4>
                                العناوين
                            </h4>
                            <ol class="breadcrumb justify-content-center">
                                <li class="breadcrumb-item">
                                    <a href="/">الرئيسية</a>
                                 </li>
                                <li class="breadcrumb-item active">
                                   العناوين
                                </li>
                            </ol>
                        </div>
                    </div>
                </section>
              </section>
            <div class="container oe_address_list">                    
                <div class="row">
                    <div class="col-md-12">
                        <div class="row all_shipping">
                            <div class="col-lg-12">
                                <div class="row mt8">
                                    <div class="col-lg-12">
                                        <h3 class="o_page_header mt8"><span class="h4-fs">الموقع الرئيسي(المعرض - المحل - المكتب)</span></h3>
                                    </div>
                                    <t t-foreach="billing" t-as="bill">
                                        <div class="form-group col-md-4">
                                            <div class="card border border-primary">
                                                <div class="card-body" style="min-height: 130px;">
                                                    <t t-out="bill" t-options="dict(widget='contact', fields=['name', 'address'], no_marker=True)"/>      
                                                </div>
                                                <div class="card-footer">
                                                    <a role="button" t-attf-href="/add-address?edit-mode=#{bill.id}" class="edit_address float-start">تحرير</a>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                            <div class="col-lg-12">
                                <div class="row mt8">
                                    <div class="col-lg-12">
                                        <h3 class="o_page_header mt8"><span class="h4-fs">عنوان توصيل المنتجات</span></h3>
                                    </div>
                                    <div class="col-md-12 col-lg-12 one_kanban">
                                        <a role="button" href="/add-address?new-address=1" class="btn btn-secondary mb16 btn-block w-100">
                                            <i class="fa fa-plus-square"/>
                                            <span>اضافة عنوان</span>
                                        </a>
                                    </div>                                        
                                    <t t-foreach="shippings" t-as="ship">
                                        <div class="form-group col-md-4">

                                            <div class="card border border-primary">
                                                <div class="card-body" style="min-height: 170px;">
                                                    <t t-out="ship" t-options="dict(widget='contact', fields=['name', 'address'], no_marker=True)"/>      
                                                </div>
                                                
                                                <t t-if="ship.id == request.env.user.partner_id.default_shipping_id.id">
                                                    <div class="card-footer" style="background-color:#cef1ce;"> 
                                                         <a role="button" t-attf-href="/update-addres/#{ship.id}" class="float-end set_default_address">افتراضي</a>
                                                         <t t-if="shipping_count != 1">
                                                            <a role="button" style="margin-left: 80px;" t-attf-href="/delete-address/#{ship.id}" class="">حذف</a>
                                                        </t>
                                                        <a role="button" t-attf-href="/add-address?edit-mode=#{ship.id}" class="edit_address float-start">تحرير</a>
                                                    </div>
                                                </t>
                                                <t t-else="">
                                                     <div class="card-footer"> 
                                                        <a role="button" t-attf-href="/update-addres/#{ship.id}" class="float-end set_default_address">افتراضي</a>
                                                        <t t-if="shipping_count != 1">
                                                            <a role="button" style="margin-left: 80px;" t-attf-href="/delete-address/#{ship.id}" class="">حذف</a>
                                                        </t>
                                                        <a role="button" t-attf-href="/add-address?edit-mode=#{ship.id}" class="edit_address float-start">تحرير</a>
                                                    </div>
                                                </t>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</t>