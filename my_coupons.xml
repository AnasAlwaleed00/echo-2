<t name="Partner Coupons Page" t-name="partner_website_registration.portal_partner_coupons_page">
    <t t-call="portal.portal_layout">

        <!-- Tailwind -->
        <script src="https://cdn.tailwindcss.com"/>
        <script>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            primary: '#28a745',
                            warning: '#facc15',
                            danger: '#dc2626',
                        }
                    }
                }
            }
        </script>

        <style>
            * { font-family: 'Cairo', sans-serif !important; }
            
            .countdown-container {
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 8px;
                padding: 6px 10px;
                border-radius: 12px;
                font-size: 12px;
                font-weight: 600;
                background: #16a34a;
                color: white;
                max-width: 100%;
            }
            
            /* States */
            .countdown-container.warning {
                background: #facc15;
                color: #000;
            }
            .countdown-container.expired {
                background: #dc2626;
                color: #fff;
            }
            
            /* Timer Unit */
            .countdown-part {
                display: flex;
                flex-direction: column;
                align-items: center;
                min-width: 44px;
            }
            
            /* Number */
            .countdown-value {
                font-size: 15px;
                font-weight: 700;
                line-height: 1;
            }
            
            /* Label */
            .countdown-part span:last-child {
                font-size: 10px;
                opacity: 0.85;
            }
            
            /* ===============================
               📱 Mobile Layout (Stacked)
            ================================ */
            @media (max-width: 640px) {
                .countdown-container {
                    display: grid;                      /* 👈 key change */
                    <!--grid-template-columns: repeat(2, 1fr);-->
                    gap: 6px;
                    padding: 8px;
                    text-align: center;
                }
            
                .countdown-part {
                    min-width: auto;
                }
            
                .countdown-value {
                    font-size: 14px;
                }
            
                .countdown-part span:last-child {
                    font-size: 9px;
                }
            }
        </style>

        <div class="min-h-screen py-6 px-4" dir="rtl">
            <div class="max-w-7xl mx-auto">

                <!-- Title -->
                <div class="mb-6">
                    <h3 class="text-2xl md:text-3xl font-bold text-gray-900">
                        🎟️ كوبونات العميل
                    </h3>
                </div>

                <!-- ================= Desktop Table ================= -->
                <div class="hidden lg:block bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="bg-gray-100 border-b">
                                <tr>
                                    <th class="px-4 py-3 text-sm font-semibold text-right">رمز الكوبون</th>
                                    <th class="px-4 py-3 text-sm font-semibold text-right">تاريخ الانتهاء</th>
                                    <th class="px-4 py-3 text-sm font-semibold text-center">المدة المتبقية</th>
                                    <th class="px-4 py-3 text-sm font-semibold text-center">قيمة الخصم</th>
                                    <th class="px-4 py-3 text-sm font-semibold text-center">الحالة</th>
                                    <th class="px-4 py-3 text-sm font-semibold text-center">نسخ</th>
                                </tr>
                            </thead>

                            <tbody class="divide-y">
                                <t t-if="not coupons">
                                    <tr>
                                        <td colspan="6" class="py-8 text-center text-gray-500">
                                            لا توجد كوبونات متاحة حالياً
                                        </td>
                                    </tr>
                                </t>

                                <t t-foreach="coupons" t-as="coupon">
                                    <t t-set="is_expired" t-value="coupon['expiration_date'] and coupon['is_expired']"/>
                                    <tr t-attf-class="#{'bg-gray-50 text-gray-400' if is_expired else 'hover:bg-gray-50'}">

                                        <td class="px-4 py-3 text-sm font-medium">
                                            <t t-esc="coupon['code']"/>
                                        </td>

                                        <td class="px-4 py-3 text-sm">
                                            <t t-esc="coupon['expiration_date'] or 'غير محدد'"/>
                                        </td>

                                        <!-- Countdown -->
                                        <td class="px-4 py-3 text-center">
                                            <t t-if="is_expired">
                                                <span class="px-3 py-1 text-xs font-semibold text-white bg-red-600 rounded-full">
                                                    منتهي
                                                </span>
                                            </t>
                                            <t t-elif="coupon['days_left'] == 0">
                                                <span class="px-3 py-1 text-xs font-semibold text-gray-900 bg-yellow-400 rounded-full">
                                                    ينتهي اليوم
                                                </span>
                                            </t>
                                            <t t-else="">
                                                <span class="inline-block px-3 py-1 text-xs font-semibold text-white bg-green-600 rounded lg:rounded-full countdown" t-att-id="'countdown-' + str(coupon['id'])" t-att-data-expiration="coupon['expiration_date']">
                                                    <t t-esc="coupon['days_left']"/> يوم
                                                </span>
                                            </t>
                                        </td>

                                        <!-- Discount -->
                                        <td class="px-4 py-3 text-center font-bold">
                                            <t t-esc="'٪%d' % int(coupon['points'])"/>
                                        </td>

                                        <!-- Status -->
                                        <td class="px-4 py-3 text-center">
                                            <t t-if="coupon['use_count'] and coupon['use_count'] &gt; 0">
                                                <span class="px-3 py-1 text-xs font-semibold bg-yellow-400 text-gray-900 rounded-full">
                                                    مستخدم
                                                </span>
                                            </t>
                                            <t t-elif="is_expired">
                                                <span class="px-3 py-1 text-xs font-semibold bg-red-600 text-white rounded-full">
                                                    منتهي
                                                </span>
                                            </t>
                                            <t t-else="">
                                                <span class="px-3 py-1 text-xs font-semibold bg-green-600 text-white rounded-full">
                                                    ساري
                                                </span>
                                            </t>
                                        </td>

                                        <!-- Copy -->
                                        <td class="px-4 py-3 text-center">
                                            <button class="copy-btn inline-flex items-center justify-center w-9 h-9 rounded-lg border hover:bg-gray-100 transition" t-att-data-code="coupon['code']" t-att-disabled="is_expired" t-att-title="'منتهي' if is_expired else 'نسخ الكود'">
                                                <i t-attf-class="fa #{'fa-ban text-red-600' if is_expired else 'fa-copy'}"/>
                                            </button>
                                        </td>

                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- ================= Mobile Cards ================= -->
                <div class="lg:hidden space-y-4">
                    <t t-if="not coupons">
                        <div class="bg-white p-6 rounded-xl shadow border text-center text-gray-500">
                            لا توجد كوبونات متاحة حالياً
                        </div>
                    </t>

                    <t t-foreach="coupons" t-as="coupon">
                        <t t-set="is_expired" t-value="coupon['expiration_date'] and coupon['is_expired']"/>

                        <div class="bg-white rounded-xl shadow border p-4 space-y-3">

                            <div class="flex justify-between items-center border-b pb-2">
                                <div>
                                    <p class="text-xs text-gray-500">رمز الكوبون</p>
                                    <p class="font-bold"><t t-esc="coupon['code']"/></p>
                                </div>

                                <t t-if="is_expired">
                                    <span class="px-3 py-1 text-xs bg-red-600 text-white rounded-full">منتهي</span>
                                </t>
                                <t t-elif="coupon['use_count']">
                                    <span class="px-3 py-1 text-xs bg-yellow-400 rounded-full">مستخدم</span>
                                </t>
                                <t t-else="">
                                    <span class="px-3 py-1 text-xs bg-green-600 text-white rounded-full">ساري</span>
                                </t>
                            </div>

                            <div class="flex justify-between text-sm">
                                <span class="text-gray-500">تاريخ الانتهاء</span>
                                <span><t t-esc="coupon['expiration_date'] or 'غير محدد'"/></span>
                            </div>

                            <div class="flex justify-between items-center">
                                <span class="text-gray-500">المدة المتبقية</span>
                                <span t-if="not is_expired" class="countdown px-3 py-1 text-xs text-white bg-green-600 rounded" t-att-id="'countdown-' + str(coupon['id'])" t-att-data-expiration="coupon['expiration_date']">
                                    <t t-esc="coupon['days_left']"/> يوم
                                </span>
                                <span t-if="is_expired" class="text-red-600 font-semibold">منتهي</span>
                            </div>

                            <div class="flex justify-between items-center pt-2 border-t">
                                <span class="font-semibold">قيمة الخصم</span>
                                <span class="text-lg font-bold">
                                    <t t-esc="'٪%d' % int(coupon['points'])"/>
                                </span>
                            </div>

                            <button class="copy-btn w-full py-2 rounded-lg border font-semibold hover:bg-gray-100 transition" t-att-data-code="coupon['code']" t-att-disabled="is_expired">
                                نسخ الكود
                            </button>
                        </div>
                    </t>
                </div>

            </div>
        </div>

<script>
    document.addEventListener('DOMContentLoaded', function () {

        // 🔹 زر النسخ
        document.querySelectorAll('.copy-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                if (btn.disabled) return;
                const code = this.getAttribute('data-code');
                navigator.clipboard.writeText(code).then(() =&gt; {
                    btn.innerHTML = '&lt;i class="fa fa-check text-success"&gt;&lt;/i&gt;';
                    setTimeout(() =&gt; {
                        btn.innerHTML = '&lt;i class="fa fa-copy"&gt;&lt;/i&gt;';
                    }, 1500);
                });
            });
        });

        // 🔹 عداد الكوبونات
        document.querySelectorAll('[id^="countdown-"]').forEach(function (el) {
            const expDate = el.getAttribute('data-expiration');
            if (!expDate) return;

            const countDownDate = new Date(expDate).getTime();

            const updateCountdown = function () {
                const now = new Date().getTime();
                const distance = countDownDate - now;

                // انتهى الكوبون
                if (distance &lt; 0) {
                    el.innerHTML = `
                        &lt;div class="countdown-container expired"&gt;
                            &lt;span&gt;منتهي&lt;/span&gt;
                        &lt;/div&gt;`;
                    const btn = el.closest("tr").querySelector('.copy-btn');
                    if (btn) btn.disabled = true;
                    clearInterval(interval);
                    return;
                }

                // حساب الوقت المتبقي
                const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                // تحديد لون العدّاد حسب المدة المتبقية
                let containerClass = "countdown-container";
                if (days &lt;= 1) containerClass += " warning";
                if (days &lt;= 0 &amp;&amp; hours &lt;= 0 &amp;&amp; minutes &lt;= 0 &amp;&amp; seconds &lt;= 0) containerClass += " expired";

                // عرض العدّاد بشكل أنيق
                el.innerHTML = `
                    &lt;div class="${containerClass}"&gt;
                        &lt;div class="countdown-part"&gt;
                            &lt;span class="countdown-value"&gt;${days}&lt;/span&gt;
                            &lt;span&gt;يوم&lt;/span&gt;
                        &lt;/div&gt;
                        &lt;div class="countdown-part"&gt;
                            &lt;span class="countdown-value"&gt;${hours}&lt;/span&gt;
                            &lt;span&gt;ساعة&lt;/span&gt;
                        &lt;/div&gt;
                        &lt;div class="countdown-part"&gt;
                            &lt;span class="countdown-value"&gt;${minutes}&lt;/span&gt;
                            &lt;span&gt;دقيقة&lt;/span&gt;
                        &lt;/div&gt;
                        &lt;div class="countdown-part"&gt;
                            &lt;span class="countdown-value"&gt;${seconds}&lt;/span&gt;
                            &lt;span&gt;ثانية&lt;/span&gt;
                        &lt;/div&gt;
                    &lt;/div&gt;
                `;
            };

            updateCountdown(); // تحديث فوري عند التحميل
            const interval = setInterval(updateCountdown, 1000);
        });
    });
</script>

    </t>
</t>