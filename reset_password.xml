<t name="Reset Password" t-name="website_vat_reset.reset_password_page">
    <t t-call="website.layout">
        <div id="wrap" class="oe_structure">
            <style>
                .auth-card { border: none; border-radius: 15px; background: #ffffff; box-shadow: 0 10px 30px rgba(0,0,0,0.05) !important; }
                .form-label { font-size: 0.95rem; color: #000; margin-bottom: 8px; display: block; text-align: right; }
                .form-control { border-radius: 8px; padding: 12px; background-color: #f8f9fa; border: 1px solid #dee2e6; }
                .btn-action { border-radius: 8px; padding: 14px; font-weight: 700; background-color: #ffb300; border: none; color: #000; }
                .btn-action:hover { background-color: #ffa000; }
                .step-badge { width: 30px; height: 30px; background: #e9ecef; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-left: 10px; font-weight: bold; color: #6c757d; }
                .active-step .step-badge { background: #007bff; color: #fff; }
            </style>

            <div class="container mt-5 py-5" dir="rtl">
                <div class="row justify-content-center">
                    <div class="col-md-6 col-lg-5">
                        <div class="card auth-card p-4 p-md-5">
                            <div class="auth-header text-center mb-5">
                                <h3>استعادة الحساب</h3>
                                <p class="text-muted">يرجى اتباع الخطوات لتأمين حسابك</p>
                            </div>
                            <div id="msg_error" class="alert alert-danger d-none text-center fade show"/>

                            <!-- الخطوة 1 -->
                            <div id="step_1" class="step-container active-step">
                                <h5 class="mb-4 text-right"><span class="step-badge">1</span> التحقق من الهوية</h5>
                                <div class="form-group mb-3 text-right">
                                    <label class="form-label fw-bold mb-2">الفرع <span class="text-danger">*</span></label>
                                    <select id="branch_select" class="form-control text-center">
                                        <option value="">-- اختر الفرع --</option>
                                        <option value="JED(121012)-">جدة</option>
                                        <option value="RYDH(121011)-">الرياض</option>
                                        <option value="KHAM(121013)-">خميس مشيط</option>
                                        <option value="QAS(121015)-">القصيم</option>
                                        <option value="JAZ(121014)-">جازان</option>
                                    </select>
                                </div>
                                <div class="form-group mb-3 text-right">
                                    <label class="form-label fw-bold mb-2">الرقم المرجعي (4 أرقام) <span class="text-danger">*</span></label>
                                    <input type="text" id="input_ref" class="form-control text-center" maxlength="4" placeholder="0000"/>
                                </div>
                                <div class="form-group mb-4 text-right">
                                    <label class="form-label fw-bold mb-2">رقم السجل التجاري أو الرقم الموحد (700) <span class="text-danger">*</span></label>
                                    <input type="text" id="input_id" class="form-control text-center" placeholder="مثال: 700xxxxxxxx"/>
                                </div>
                                <button class="btn btn-primary btn-action w-100 shadow-sm" id="btn_verify_id">تحقق من البيانات</button>
                            </div>

                            <!-- الخطوة 2 -->
                          <!-- الخطوة 2: تأكيد الجوال -->
<div id="step_2" class="d-none step-container">
<h5 class="mb-4 text-right"><span class="step-badge">2</span> تأكيد الجوال</h5>
<div class="alert alert-info text-center py-3 mb-4">
    <!-- أضفنا span حول النص لتثبيت الاتجاه وأخر لتمثيل الرقم -->
    <div class="d-flex flex-row-reverse justify-content-center align-items-center">
        <span class="ms-1">اكتب رقم الجوال المنتهي بـ:</span>
        <strong id="display_masked" class="fs-5" dir="ltr" style="display: inline-block; letter-spacing: 2px;"/>
    </div>
</div>
<div class="input-group mb-4 shadow-sm" dir="ltr">
    <input type="text" id="input_mobile" class="form-control text-center" placeholder="5xxxxxxxx"/>
    <span class="input-group-text">966+</span>
</div>
<button class="btn btn-success btn-action w-100" id="btn_send_otp">إرسال كود التحقق (OTP)</button>
</div>
                            <!-- الخطوة 3 -->
                            <div id="step_3" class="d-none step-container">
                                <h5 class="mb-4 text-right"><span class="step-badge">3</span> رمز التحقق</h5>
                                <div class="form-group mb-4">
                                    <label class="form-label fw-bold text-center d-block">أدخل الرمز المكون من 6 أرقام</label>
                                    <input type="text" id="input_otp" class="form-control text-center fs-4 fw-bold" maxlength="6" style="letter-spacing: 8px;"/>
                                </div>
                                <button class="btn btn-primary btn-action w-100" id="btn_verify_otp">تأكيد الرمز</button>
                            </div>

                            <!-- الخطوة 4 -->
                            <div id="step_4" class="d-none step-container">
                                <h5 class="mb-4 text-right"><span class="step-badge">4</span> تعيين كلمة المرور</h5>
                                <div class="form-group mb-3 text-right">
                                    <label class="form-label fw-bold">كلمة المرور الجديدة</label>
                                    <input type="password" id="new_password" class="form-control"/>
                                </div>
                                <div class="form-group mb-4 text-right">
                                    <label class="form-label fw-bold">تأكيد كلمة المرور</label>
                                    <input type="password" id="confirm_password" class="form-control"/>
                                </div>
                                <button class="btn btn-success btn-action w-100" id="btn_finish">تحديث الحساب والولوج</button>
                            </div>

                            <div class="text-center mt-4">
                                <a href="/web/custom/login" class="small text-muted">العودة لتسجيل الدخول</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <script type="text/javascript" src="/website_vat_reset/static/src/js/password_reset.js"/>
    </t>
</t>