<t name="Homepage" t-name="website.homepage">
    <t t-call="website.layout">
        <t t-set="pageName" t-value="'homepage'"/>

        <div id="wrap" class="oe_structure">

            <section class="custom-hero-slider o_colored_level" style="background-image: none;">
                <div id="novixHeroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000" style="background-image: none;">

                    
                    <div class="carousel-indicators o_we_no_overlay">
                        <button type="button" data-bs-target="#novixHeroCarousel" data-bs-slide-to="0" class="active" aria-current="true"/>
                        <button type="button" data-bs-target="#novixHeroCarousel" data-bs-slide-to="1"/>
                        <button type="button" data-bs-target="#novixHeroCarousel" data-bs-slide-to="2"/>
                    </div>

                    
                    <div class="carousel-inner">
                        
                        <div class="carousel-item active o_colored_level" style="background-image: none; min-height: 650px;">
                            <img src="/web/image/55303-39f2595b/صدي 03_ (4).jpg" class="d-block w-100 slider-img" loading="lazy"/>
                        </div>

                        
                        <div class="carousel-item" style="min-height: 650px;">
                            <img src="/web/image/58358-3258b93a/Blog Post 'نجاح منتجات أوريسا في السوق السعودي' cover image.webp" class="d-block w-100 slider-img" loading="lazy"/>
                        </div>

                        
                        <div class="carousel-item o_colored_level" style="background-image: none; min-height: 650px;">
                            <img src="/web/image/58359-6a70d0be/صدي 02_ (4).webp" class="d-block w-100 slider-img" loading="lazy"/>
                        </div>

                    </div>

                    
                   <button class="carousel-control-prev novix-arrow" type="button" data-bs-target="#novixCategoryCarousel" data-bs-slide="prev">

    <span class="novix-gold-arrow">
        <svg viewBox="0 0 24 24" width="22" height="22">
            <path d="M15 18l-6-6 6-6" fill="none" stroke="#d4af37" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </span>

</button>

<button class="carousel-control-next novix-arrow" type="button" data-bs-target="#novixCategoryCarousel" data-bs-slide="next">

    <span class="novix-gold-arrow">
        <svg viewBox="0 0 24 24" width="22" height="22">
            <path d="M9 6l6 6-6 6" fill="none" stroke="#d4af37" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </span>

</button>


                </div>
            </section>

        </div>
<!-- ================= Categories Section ================= -->
<!-- ================= Categories Carousel ================= -->
<section class="novix-category-carousel oe_structure">
    <div class="container">

        <div class="text-center mb-5">
            <h2 class="fw-bold">تسوق حسب التصنيف</h2>
        </div>

        <div id="novixCategoryCarousel" class="carousel slide">

            <div class="carousel-inner">

                <t t-set="categories" t-value="request.env['product.public.category'].sudo().search([('parent_id','=',False)])"/>

                <t t-set="chunk_size" t-value="6"/>

                <t t-foreach="range(0, len(categories), chunk_size)" t-as="i">

                    <div t-attf-class="carousel-item #{'active' if i == 0 else ''}">
                        <div class="row justify-content-center">

                            <t t-foreach="categories[i:i+chunk_size]" t-as="category">
                                <div class="col-lg-2 col-md-2 col-4 mb-4">

                                    <a t-att-href="'/shop/category/%s' % slug(category)" class="novix-category-card">

                                        <!-- شريط العلامة التجارية -->
                                        <div class="novix-brand-badge">
                                            ORISA
                                        </div>

                                        <!-- الصورة -->
                                        <div class="novix-category-image">
                                            <img t-att-src="'/web/image/product.public.category/%s/image_1920' % category.id"/>
                                        </div>

                                        <!-- العنوان -->
                                        <div class="novix-category-title">
                                            <h6 t-esc="category.name"/>
                                        </div>

                                    </a>

                                </div>
                            </t>

                        </div>
                    </div>

                </t>

            </div>

            <!-- أزرار التنقل -->
           <!-- سهم للرجوع -->
<button class="novix-arrow" type="button" data-bs-target="#novixCategoryCarousel" data-bs-slide="prev">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24">
        <path d="M15 18l-6-6 6-6" fill="none" stroke="#d4af37" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
</button>

<!-- سهم للأمام -->
<button class="novix-arrow" type="button" data-bs-target="#novixCategoryCarousel" data-bs-slide="next">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24">
        <path d="M9 6l6 6-6 6" fill="none" stroke="#d4af37" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
</button>


        </div>

    </div>
</section>

<style>
/* ===== القسم ===== */
.novix-category-carousel {
    padding: 20px;
    background: #f8f9fa;
}

/* ===== البطاقة ===== */
.novix-category-card {
    position: relative;
    display: block;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    text-align: center;
    transition: all 0.3s ease;
    text-decoration: none;
    box-shadow: 0 6px 20px rgba(0,0,0,0.06);
}

.novix-category-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.15);
}

/* ===== شريط ORISA ===== */
.novix-brand-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: linear-gradient(45deg, #c9a227, #f2d57e);
    color: #000;
    font-size: 10px;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 20px;
    z-index: 10;
    letter-spacing: 1px;
}

/* ===== الصورة ===== */
.novix-category-image {
    height: 100px;
    padding: 10px;
}

.novix-category-image img {
    width: 90px;
    height: 90px;
    object-fit: cover;
    border-radius: 12px;
    transition: 0.4s ease;
}

.novix-category-card:hover img {
    transform: scale(1.08);
}

/* ===== العنوان الذهبي ===== */
.novix-category-title {
    background: linear-gradient(45deg, #c9a227, #f2d57e);
    padding: 6px 5px;
}

.novix-category-title h6 {
    margin: 0;
    font-size: 12px;
    font-weight: 700;
    color: #000;
}

/* ===== الأسهم ===== */
/* خلفية الزر */
.novix-arrow {
    position: absolute;
    top: 45%;
    transform: translateY(-50%);
    width: 50px;
    height: 50px;
    background: #000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.9;
    border: none;
    cursor: pointer;
    z-index: 10;
    transition: all 0.3s ease;
}

.novix-arrow:hover {
    background: #111;
    box-shadow: 0 0 12px rgba(212, 175, 55, 0.6);
}

/* سهم SVG داخلي */
.novix-arrow svg path {
    stroke: #d4af37; /* ذهبي واضح */
}

/* توجيه الزر السابق لليسار */
.novix-arrow[data-bs-slide="prev"] {
    left: -25px;
}

/* توجيه الزر التالي لليمين */
.novix-arrow[data-bs-slide="next"] {
    right: -25px;
}

/* إخفاء أيقونات Bootstrap الافتراضية */
.carousel-control-prev-icon,
.carousel-control-next-icon {
    display: none;
}

/* ===== استجابة الموبايل ===== */
@media (max-width: 768px) {

    /* ===== عرض الصفوف بشكل أفقي مع سحب ===== */
    .row.justify-content-center {
        flex-wrap: nowrap;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scroll-behavior: smooth;
        margin-left: -5px;  /* لتقليل الهوامش الخارجية */
    }

    /* كل بطاقة بعرض 50% تقريبًا لعرض بطاقتين في الصف */
    .col-lg-2, .col-md-2, .col-4 {
        flex: 0 0 auto;
        width: 48%;
        margin-right: 4%;
    }

    /* الصور داخل البطاقة */
    .novix-category-image {
        height: 70px;
        padding: 5px;
    }

    .novix-category-image img {
        width: 60px;
        height: 60px;
        object-fit: cover;
    }

    /* عنوان البطاقة */
    .novix-category-title h6 {
        font-size: 10px;
        font-weight: 600;
        margin: 4px 0;
    }

    /* الشارة ORISA */
    .novix-brand-badge {
        font-size: 8px;
        padding: 2px 6px;
        top: 4px;
        left: 4px;
    }

    /* الأسهم */
    .novix-arrow {
        width: 35px;
        height: 35px;
        top: 40%;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.9;
    }

    .novix-arrow svg {
        width: 18px;
        height: 18px;
    }
}

</style>
<script>
document.addEventListener('DOMContentLoaded', function () {
    var myCarousel = document.querySelector('#novixCategoryCarousel');
    if (myCarousel) {
        new bootstrap.Carousel(myCarousel, {
            interval: 3000,
            ride: 'carousel',
            pause: false,
            wrap: true
        });
    }
});
</script>

<!-- تفعيل الحركة بالقوة -->
<script>
document.addEventListener('DOMContentLoaded', function () {
    var myCarousel = document.querySelector('#novixCategoryCarousel');
    if (myCarousel) {
        new bootstrap.Carousel(myCarousel, {
            interval: 3000,
            ride: 'carousel',
            pause: false,
            wrap: true
        });
    }
});
</script>

        <!-- Custom CSS -->
        <style>
            .custom-hero-slider {
                width: 100%;
                overflow: hidden;
            }

            .slider-img {
                height: 650px;
                object-fit: cover;
            }

            @media (max-width: 992px) {
                .slider-img {
                    height: 450px;
                }
            }

            @media (max-width: 576px) {
                .slider-img {
                    height: 300px;
                }
            }
        </style>

    </t>
</t>