<t name="My Sales Orders" t-name="sale.portal_my_orders">
    <t t-call="portal.portal_layout">
        <t t-set="breadcrumbs_searchbar" t-value="True"/>
        <t t-call="portal.portal_searchbar">
            <t t-set="title">طلباتي</t>
        </t>

        <div class="o_portal_wrap">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

                <!-- Page Header -->
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <h1 class="text-2xl font-bold text-gray-900">طلباتي</h1>
                        <p class="text-sm text-gray-500 mt-1">تتبع حالة طلباتك وتفاصيل الشحن</p>
                    </div>
                    <t t-if="orders">
                        <span class="inline-flex items-center gap-1.5 bg-blue-50 text-blue-700 text-sm font-medium px-3 py-1.5 rounded-full border border-blue-100">
                            <t t-out="len(orders)"/>
                            طلب
                        </span>
                    </t>
                </div>

                <!-- Empty State -->
                <t t-if="not orders">
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm flex flex-col items-center justify-center py-20 px-6 text-center">
                        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M16 10a4 4 0 0 1-8 0"/>
                                <path d="M3.103 6.034h17.794"/>
                                <path d="M3.4 5.467a2 2 0 0 0-.4 1.2V20a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6.667a2 2 0 0 0-.4-1.2l-2-2.667A2 2 0 0 0 17 2H7a2 2 0 0 0-1.6.8z"/>
                            </svg>
                        </div>
                        <h3 class="text-base font-semibold text-gray-800 mb-1">لا توجد طلبات بعد</h3>
                        <p class="text-sm text-gray-500 max-w-xs">لم يتم تسجيل أي طلبات لحسابك حتى الآن. ستظهر طلباتك هنا فور إنشائها.</p>
                    </div>
                </t>

                <!-- Orders Table -->
                <t t-if="orders">
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">

                        <!-- Desktop Table -->
                        <div class="hidden md:block overflow-x-auto">
                            <table class="w-full">
                                <thead>
                                    <tr class="bg-gray-50 border-b border-gray-200">
                                        <th class="px-6 py-3.5 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">رقم الطلب</th>
                                        <th class="px-6 py-3.5 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">التاريخ</th>
                                        <th class="px-6 py-3.5 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">الحالة</th>
                                        <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">الإجمالي</th>
                                        <th class="px-6 py-3.5"></th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    <t t-foreach="orders" t-as="order">
                                        <tr class="hover:bg-gray-50 transition-colors duration-150 group">

                                            <!-- Order Number -->
                                            <td class="px-6 py-4">
                                                <a t-att-href="order.get_portal_url()" class="font-semibold text-blue-600 hover:text-blue-800 hover:underline text-sm">
                                                    <t t-out="order.name"/>
                                                </a>
                                            </td>

                                            <!-- Date -->
                                            <td class="px-6 py-4">
                                                <div class="text-sm text-gray-700">
                                                    <span t-field="order.date_order" t-options="{'widget': 'date'}"/>
                                                </div>
                                                <div class="text-xs text-gray-400 mt-0.5">
                                                    <span t-field="order.date_order" t-options="{'time_only': True}"/>
                                                </div>
                                            </td>

                                            <!-- Status -->
                                            <td class="px-6 py-4 text-center">
                                                <t t-if="order.state in ('sale','done')">
                                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-100">
                                                        <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                                                        مؤكد
                                                    </span>
                                                </t>
                                                <t t-elif="order.state == 'draft' and order.price_state != 'price_set'">
                                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200">
                                                        <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>
                                                        غير مسعّر
                                                    </span>
                                                </t>
                                                <t t-elif="order.state == 'draft' and order.price_state == 'price_set'">
                                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-100">
                                                        <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                                                        في انتظار التأكيد
                                                    </span>
                                                </t>
                                            </td>

                                            <!-- Total -->
                                            <td class="px-6 py-4 text-left">
                                                <t t-if="order.state in ('sale','done') or order.price_state == 'price_set'">
                                                    <span class="font-semibold text-gray-900 text-sm" t-field="order.amount_total"/>
                                                </t>
                                                <t t-else="">
                                                    <span class="text-xs text-gray-400 italic">بعد التسعير</span>
                                                </t>
                                            </td>

                                            <!-- View Arrow -->
                                            <td class="px-4 py-4 text-right">
                                                <a t-att-href="order.get_portal_url()" class="text-gray-300 group-hover:text-blue-500 transition-colors duration-150">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <path d="m15 18-6-6 6-6"/>
                                                    </svg>
                                                </a>
                                            </td>

                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <!-- Mobile Cards -->
                        <div class="md:hidden divide-y divide-gray-100">
                            <t t-foreach="orders" t-as="order">
                                <a t-att-href="order.get_portal_url()" class="flex items-center justify-between p-4 hover:bg-gray-50 transition-colors duration-150 block">

                                    <div class="flex-1 min-w-0">
                                        <!-- Order name + status row -->
                                        <div class="flex items-center justify-between gap-2 mb-1.5">
                                            <span class="font-semibold text-blue-600 text-sm truncate">
                                                <t t-out="order.name"/>
                                            </span>
                                            <t t-if="order.state in ('sale','done')">
                                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-100 shrink-0">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                                                    مؤكد
                                                </span>
                                            </t>
                                            <t t-elif="order.state == 'draft' and order.price_state != 'price_set'">
                                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-600 border border-gray-200 shrink-0">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>
                                                    غير مسعّر
                                                </span>
                                            </t>
                                            <t t-elif="order.state == 'draft' and order.price_state == 'price_set'">
                                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-100 shrink-0">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                                                    في انتظار التأكيد
                                                </span>
                                            </t>
                                        </div>

                                        <!-- Date + Total row -->
                                        <div class="flex items-center justify-between">
                                            <span class="text-xs text-gray-400">
                                                <span t-field="order.date_order" t-options="{'widget': 'date'}"/>
                                            </span>
                                            <t t-if="order.state in ('sale','done') or order.price_state == 'price_set'">
                                                <span class="text-sm font-semibold text-gray-800" t-field="order.amount_total"/>
                                            </t>
                                            <t t-else="">
                                                <span class="text-xs text-gray-400 italic">بعد التسعير</span>
                                            </t>
                                        </div>
                                    </div>

                                    <!-- Chevron -->
                                    <div class="mr-3 text-gray-300 shrink-0">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="m15 18-6-6 6-6"/>
                                        </svg>
                                    </div>

                                </a>
                            </t>
                        </div>

                    </div>
                </t>

            </div>
        </div>
    </t>
</t>
