            <script>

                document.addEventListener("DOMContentLoaded", function () {

    // الكود الحالي الخاص بك...

    

    // سطر إضافي لضمان تعيين الحالة الافتراضية إذا لم تكن موجودة:

    if (!document.querySelector(".help-link.active")) {

        document.querySelector("[data-target='about']").classList.add("active");

        document.getElementById("about").classList.add("active");

    }

});

                document.addEventListener("DOMContentLoaded", function () {

                    const links = document.querySelectorAll(".help-link");

                    const sections = document.querySelectorAll(".help-section");

                    links.forEach(link =&gt; {

                        link.addEventListener("click", function () {

                            const target = this.getAttribute("data-target");

                            links.forEach(l =&gt; l.classList.remove("active"));

                            sections.forEach(s =&gt; s.classList.remove("active"));

                            this.classList.add("active");

                            document.getElementById(target).classList.add("active");

                            window.scrollTo({ top: 400, behavior: 'smooth' });

                        });

                    });

                });

