<t name="My Portal" t-name="portal.portal_my_home">
    <t t-call="portal.portal_layout">
        <t t-set="my_details" t-value="True"/>
        
        
        <div class="max-w-6xl mx-auto">
            <div class="mb-6" style="margin-right:50px !important">
                <h3 class="text-2xl font-bold text-gray-900">إدارة الحساب</h3>
                <p class="text-gray-600">قم بإدارة حسابك ومتابعة طلباتك وفواتيرك</p>
                
            </div>
            
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                <!-- Orders Card -->
                <a class="account-card flex flex-col gap-3 border border-gray-200 bg-white p-3 rounded-lg hover:border-blue-400" href="/my/orders">
                    <div class="icon-wrapper p-2.5 rounded-lg w-fit shadow-md shadow-blue-500/25">
                        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 10a4 4 0 0 1-8 0"/>
                            <path d="M3.103 6.034h17.794"/>
                            <path d="M3.4 5.467a2 2 0 0 0-.4 1.2V20a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6.667a2 2 0 0 0-.4-1.2l-2-2.667A2 2 0 0 0 17 2H7a2 2 0 0 0-1.6.8z"/>
                        </svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-lg text-gray-900 mb-1">طلباتي</h4>
                        <p class="text-sm text-gray-600 leading-relaxed">تتبع حالة طلباتك وتفاصيل الشحن</p>
                    </div>
                </a>
                
                <!-- Invoices Card -->
                <a class="account-card flex flex-col gap-3 border border-gray-200 bg-white p-3 rounded-lg hover:border-blue-400" href="/my/invoices">
                    <div class="icon-wrapper p-2.5 rounded-lg w-fit shadow-md shadow-blue-500/25">
                        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/>
                            <path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/>
                            <path d="M12 18V6"/>
                        </svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-lg text-gray-900 mb-1">فواتيري</h4>
                        <p class="text-sm text-gray-600 leading-relaxed">عرض ودفع الفواتير المستحقة</p>
                    </div>
                </a>
                
                <!-- Password Card -->
                <a class="account-card flex flex-col gap-3 border border-gray-200 bg-white p-3 rounded-lg hover:border-blue-400" href="/my/security">
                    <div class="icon-wrapper p-2.5 rounded-lg w-fit shadow-md shadow-blue-500/25">
                        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2.586 17.414A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814a6.5 6.5 0 1 0-4-4z"/>
                            <circle cx="16.5" cy="7.5" r=".5" fill="#fff"/>
                        </svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-lg text-gray-900 mb-1">كلمة المرور</h4>
                        <p class="text-sm text-gray-600 leading-relaxed">تغيير وتحديث كلمة المرور</p>
                    </div>
                </a>
                
                <!-- Statement Card -->
                <a class="account-card flex flex-col gap-3 border border-gray-200 bg-white p-3 rounded-lg hover:border-blue-400" href="/my/customer_statement">
                    <div class="icon-wrapper p-2.5 rounded-lg w-fit shadow-md shadow-blue-500/25">
                        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M15 12h-5"/>
                            <path d="M15 8h-5"/>
                            <path d="M19 17V5a2 2 0 0 0-2-2H4"/>
                            <path d="M8 21h12a2 2 0 0 0 2-2v-1a1 1 0 0 0-1-1H11a1 1 0 0 0-1 1v1a2 2 0 1 1-4 0V5a2 2 0 1 0-4 0v2a1 1 0 0 0 1 1h3"/>
                        </svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-lg text-gray-900 mb-1">كشف حساب</h4>
                        <p class="text-sm text-gray-600 leading-relaxed">مراجعة سجل المعاملات المالية</p>
                    </div>
                </a>
                
                <!-- Agreement Card -->
                <a class="account-card flex flex-col gap-3 border border-gray-200 bg-white p-3 rounded-lg hover:border-blue-400" href="/partner/agreement">
                    <div class="icon-wrapper p-2.5 rounded-lg w-fit shadow-md shadow-blue-500/25">
                       <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text-icon lucide-file-text"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-lg text-gray-900 mb-1">الاتفاقية</h4>
                        <p class="text-sm text-gray-600 leading-relaxed">عرض تفاصيل وشروط الاتفاقية</p>
                    </div>
                </a>
                
                <!-- Attachments Card -->
                <a class="account-card flex flex-col gap-3 border border-gray-200 bg-white p-3 rounded-lg hover:border-blue-400" href="/my/attachments">
                    <div class="icon-wrapper p-2.5 rounded-lg w-fit shadow-md shadow-blue-500/25">
                      <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-stack-icon lucide-file-stack"><path d="M11 21a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-8a1 1 0 0 1 1-1"/><path d="M16 16a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1"/><path d="M21 6a2 2 0 0 0-.586-1.414l-2-2A2 2 0 0 0 17 2h-3a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1z"/></svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-lg text-gray-900 mb-1">مرفقاتي</h4>
                        <p class="text-sm text-gray-600 leading-relaxed">الوصول إلى الملفات والمستندات المرفقة</p>
                    </div>
                </a>
                
                <!-- Coupon Card -->
                <a class="account-card flex flex-col gap-3 border border-gray-200 bg-white p-3 rounded-lg hover:border-blue-400" href="/my/coupons">
                    <div class="icon-wrapper p-2.5 rounded-lg w-fit shadow-md shadow-blue-500/25">
                       <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-barcode-icon lucide-barcode"><path d="M3 5v14"/><path d="M8 5v14"/><path d="M12 5v14"/><path d="M17 5v14"/><path d="M21 5v14"/></svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-lg text-gray-900 mb-1">كوبوناتي</h4>
                        <p class="text-sm text-gray-600 leading-relaxed">استعراض وإدارة الكوبونات والعروض</p>
                    </div>
                </a>
                
                <!-- Payment Card -->
                <a class="account-card flex flex-col gap-3 border border-gray-200 bg-white p-3 rounded-lg hover:border-blue-400" href="/my/payments">
                    <div class="icon-wrapper p-2.5 rounded-lg w-fit shadow-md shadow-blue-500/25">
                       <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-spreadsheet-icon lucide-file-spreadsheet"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M8 13h2"/><path d="M14 13h2"/><path d="M8 17h2"/><path d="M14 17h2"/></svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-lg text-gray-900 mb-1">سنداتي</h4>
                        <p class="text-sm text-gray-600 leading-relaxed">مراجعة السندات والوثائق الرسمية</p>
                    </div>
                </a>
            </div>
        </div>
        
       
        <div class="o_portal_my_home">
            <div class="oe_structure" id="oe_structure_portal_my_home_1"/>
            <div class="o_portal_docs row g-2">
                <div class="o_portal_doc_spinner spinner-border text-o-color-2 align-self-center mt-5"/>
                <div t-if="portal_alert_category_enable" class="o_portal_category row g-2 mt-3" id="portal_alert_category"/>
                <div t-if="portal_client_category_enable" class="o_portal_category row g-2 mt-3" id="portal_client_category"/>
                <div t-if="portal_service_category_enable" class="o_portal_category row g-2 mt-3" id="portal_service_category"/>
                <div t-if="portal_vendor_category_enable" class="o_portal_category row g-2 mt-3" id="portal_vendor_category"/>
                <div class="o_portal_category row g-2 mt-3" id="portal_common_category">
                    <t t-call="portal.portal_docs_entry" t-if="False"/>
                    <t t-call="portal.portal_docs_entry">
                        <t t-set="icon" t-value="'/portal/static/src/img/portal-connection.svg'"/>
                        <t t-set="title">كلمة المرور </t>
                        <t t-set="text">Configure your connection parameters </t>
                        <t t-set="url" t-value="'/my/security'"/>
                        <t t-set="config_card" t-value="True"/></t>
                </div>
            </div>
        </div>
        <div class="oe_structure" id="oe_structure_portal_my_home_2"/>
    </t>
</t>