<t name="دفع العميل - الخطوة 1" t-name="website_payment_mod.customer_payment">
    <t t-call="website.layout">

        <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&amp;display=swap" rel="stylesheet"/>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"/>
        <style>
            .ecp, .ecp *, .ecp *::before, .ecp *::after { box-sizing: border-box; font-family: "Cairo", sans-serif; }
            .ecp .fa, .ecp .fa::before, .ecp i.fa, .ecp i[class*="fa-"], .ecp i[class*="fa-"]::before { font-family: FontAwesome !important; font-style: normal; font-weight: normal; line-height: 1; -webkit-font-smoothing: antialiased; }
            .ecp {
                --gold: #C9982A; --gold-dark: #A87B1E; --gold-light: rgba(201, 152, 42, 0.12);
                --navy: #0D1B2E; --bg: #F7F5F0; --card: #FFFFFF; --border: #E8E2D9;
                --text: #1A1A2E; --muted: #8A8578; --green: #16a34a; --green-bg: #f0fdf4;
                --red: #dc2626; --red-bg: #fef2f2; --blue: #2563eb; --blue-bg: #eff6ff;
                --amber: #b45309; --amber-bg: #fffbeb;
                direction: rtl; text-align: right; background: var(--bg); min-height: 60vh; padding: 24px 0 56px;
            }
            .ecp-shell { max-width: 720px; margin: 0 auto; padding: 0 20px; }
            .ecp h1, .ecp h2, .ecp h3, .ecp p { margin: 0; padding: 0; }
            .ecp a { text-decoration: none; color: inherit; }
            .ecp-header { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 20px 22px; margin-bottom: 20px; position: relative; overflow: hidden; }
            .ecp-header::before { content: ""; position: absolute; top: 0; right: 0; width: 4px; height: 100%; background: linear-gradient(180deg, #FDE021, var(--gold)); }
            .ecp-header-greet { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
            .ecp-header-greet-text { display: flex; flex-direction: column; gap: 4px; }
            .ecp-header-greet-msg { font-size: 14px; color: var(--muted); font-weight: 600; }
            .ecp-header-greet-name { font-size: 22px; color: var(--navy); font-weight: 800; line-height: 1.3; }
            .ecp-header-greet-icon { width: 32px; height: 32px; border-radius: 10px; background: var(--gold-light); display: flex; align-items: center; justify-content: center; color: var(--gold-dark); flex-shrink: 0; }
            .ecp-header-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 14px; }
            .ecp-header-stat { display: flex; align-items: center; gap: 12px; background: var(--bg); border: 1px solid var(--border); border-radius: 12px; padding: 14px 16px; }
            .ecp-header-stat-icon { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 15px; }
            .ecp-header-stat.is-balance .ecp-header-stat-icon { background: var(--gold-light); color: var(--gold-dark); }
            .ecp-header-stat.is-overdue .ecp-header-stat-icon { background: var(--red-bg); color: var(--red); }
            .ecp-header-stat-label { display: block; font-size: 11px; font-weight: 700; color: var(--muted); line-height: 1.3; }
            .ecp-header-stat-value { display: block; font-size: 20px; font-weight: 800; color: var(--navy); line-height: 1.2; margin-top: 2px; font-variant-numeric: tabular-nums; }
            .ecp-header-stat.is-overdue .ecp-header-stat-value { color: var(--red); }
            .ecp-header-stat-value small { font-size: 11px; font-weight: 700; color: var(--muted); margin-right: 4px; }
            .ecp-header-note { display: flex; align-items: flex-start; gap: 8px; font-size: 12px; font-weight: 600; color: var(--amber); background: var(--amber-bg); border: 1px solid rgba(180, 83, 9, 0.2); border-radius: 10px; padding: 10px 14px; line-height: 1.6; }
            .ecp-stepper { display: flex; align-items: center; justify-content: center; margin-bottom: 22px; padding: 0 4px; }
            .ecp-step { display: flex; flex-direction: column; align-items: center; gap: 6px; flex: 1; max-width: 120px; position: relative; }
            .ecp-step:not(:last-child)::after { content: ""; position: absolute; top: 16px; left: -50%; width: 100%; height: 2px; background: var(--border); z-index: 0; }
            .ecp-step.is-done:not(:last-child)::after, .ecp-step.is-active:not(:last-child)::after { background: var(--gold); }
            .ecp-step-dot { width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--border); background: var(--card); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 800; color: var(--muted); position: relative; z-index: 1; }
            .ecp-step.is-active .ecp-step-dot { border-color: var(--gold); background: var(--gold); color: #fff; box-shadow: 0 0 0 4px var(--gold-light); }
            .ecp-step.is-done .ecp-step-dot { border-color: var(--gold); background: var(--gold-light); color: var(--gold-dark); }
            .ecp-step-label { font-size: 11px; font-weight: 700; color: var(--muted); text-align: center; line-height: 1.3; }
            .ecp-step.is-active .ecp-step-label { color: var(--navy); }
            .ecp-step.is-done .ecp-step-label { color: var(--gold-dark); }
            .ecp-panel { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 24px 22px; margin-bottom: 16px; }
            .ecp-panel-title { font-size: 18px; font-weight: 800; color: var(--navy); margin-bottom: 6px !important; }
            .ecp-panel-sub { font-size: 13px; color: var(--muted); line-height: 1.7; margin-bottom: 20px !important; }
            .ecp-type-grid { display: flex; flex-direction: column; gap: 12px; }
            .ecp-type-card { position: relative; cursor: pointer; }
            .ecp-type-card input { position: absolute; opacity: 0; width: 0; height: 0; }
            .ecp-type-card-inner { display: flex; align-items: center; gap: 14px; padding: 16px 18px; border: 2px solid var(--border); border-radius: 14px; background: var(--card); transition: border-color 0.15s, box-shadow 0.15s; }
            .ecp-type-card:hover .ecp-type-card-inner { border-color: rgba(201, 152, 42, 0.4); box-shadow: 0 2px 12px rgba(13, 27, 46, 0.06); }
            .ecp-type-card input:checked + .ecp-type-card-inner { border-color: var(--gold); background: rgba(201, 152, 42, 0.05); box-shadow: 0 0 0 3px var(--gold-light); }
            .ecp-type-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
            .ecp-type-icon.is-full { background: var(--gold-light); color: var(--gold-dark); }
            .ecp-type-icon.is-overdue { background: var(--red-bg); color: var(--red); }
            .ecp-type-icon.is-partial { background: var(--blue-bg); color: var(--blue); }
            .ecp-type-text h4 { font-size: 15px; font-weight: 800; color: var(--navy); margin-bottom: 3px !important; }
            .ecp-type-text p { font-size: 12px; color: var(--muted); line-height: 1.5; margin: 0 !important; }
            .ecp-type-check { margin-right: auto; width: 22px; height: 22px; border-radius: 50%; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
            .ecp-type-card input:checked + .ecp-type-card-inner .ecp-type-check { border-color: var(--gold); background: var(--gold); color: #fff; }
            .ecp-actions { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding-top: 20px; margin-top: 8px; border-top: 1px solid var(--border); }
            .ecp-btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 12px 24px; border-radius: 10px; font-size: 14px; font-weight: 700; font-family: inherit; cursor: pointer; border: none; transition: all 0.15s; white-space: nowrap; }
            .ecp-btn-ghost { background: transparent; border: 1px solid var(--border); color: var(--muted); }
            .ecp-btn-ghost:hover { border-color: var(--gold); color: var(--gold-dark); background: var(--gold-light); }
            .ecp-btn-primary { background: linear-gradient(135deg, var(--gold), var(--gold-dark)); color: #fff; box-shadow: 0 4px 14px rgba(201, 152, 42, 0.3); }
            .ecp-btn-primary:hover { box-shadow: 0 6px 18px rgba(201, 152, 42, 0.4); transform: translateY(-1px); }
            @media (max-width: 520px) { .ecp-header-stats { grid-template-columns: 1fr; } .ecp-actions { flex-direction: column-reverse; } .ecp-actions .ecp-btn { width: 100%; } .ecp-step-label { font-size: 10px; } }
            @media (min-width: 768px) { .ecp { padding: 32px 0 64px; } .ecp-shell { padding: 0 32px; } .ecp-panel { padding: 28px; } }
        </style>

        <div class="ecp">
            <div class="ecp-shell">
                <t t-call="website_payment_mod.payment_portal_header"/>

                <nav class="ecp-stepper" aria-label="خطوات السداد">
                    <div class="ecp-step is-active">
                        <div class="ecp-step-dot">1</div>
                        <span class="ecp-step-label">نوع الدفع</span>
                    </div>
                    <div class="ecp-step">
                        <div class="ecp-step-dot">2</div>
                        <span class="ecp-step-label">التفاصيل</span>
                    </div>
                    <div class="ecp-step">
                        <div class="ecp-step-dot">3</div>
                        <span class="ecp-step-label">التأكيد</span>
                    </div>
                </nav>

                <div class="ecp-panel">
                    <h2 class="ecp-panel-title">اختر نوع السداد</h2>
                    <p class="ecp-panel-sub">حدّد الطريقة المناسبة لسداد مستحقاتك. يمكنك الدفع كاملاً أو جزئياً حسب رغبتك.</p>

                    <form action="/customer/payment/details" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <div class="ecp-type-grid">
                            <label class="ecp-type-card" for="payment_full">
                                <input type="radio" name="payment_type" id="payment_full" value="full" required="required" checked="checked"/>
                                <div class="ecp-type-card-inner">
                                    <div class="ecp-type-icon is-full"><i class="fa fa-check-circle"/></div>
                                    <div class="ecp-type-text">
                                        <h4>الدفع الكامل</h4>
                                        <p>سداد إجمالي الرصيد المستحق دفعة واحدة</p>
                                    </div>
                                    <div class="ecp-type-check"><i class="fa fa-check" style="font-size:11px; display:none;"/></div>
                                </div>
                            </label>

                            <t t-if="aged_90_plus and aged_90_plus &gt; 0">
                                <label class="ecp-type-card" for="payment_overdue">
                                    <input type="radio" name="payment_type" id="payment_overdue" value="overdue" required="required"/>
                                    <div class="ecp-type-card-inner">
                                        <div class="ecp-type-icon is-overdue"><i class="fa fa-clock-o"/></div>
                                        <div class="ecp-type-text">
                                            <h4>سداد المتأخرات</h4>
                                            <p>سداد المبالغ المتأخرة أكثر من 90 يوماً فقط</p>
                                        </div>
                                        <div class="ecp-type-check"><i class="fa fa-check" style="font-size:11px; display:none;"/></div>
                                    </div>
                                </label>
                            </t>

                            <label class="ecp-type-card" for="payment_partial">
                                <input type="radio" name="payment_type" id="payment_partial" value="partial" required="required"/>
                                <div class="ecp-type-card-inner">
                                    <div class="ecp-type-icon is-partial"><i class="fa fa-sliders"/></div>
                                    <div class="ecp-type-text">
                                        <h4>دفع جزئي</h4>
                                        <p>تحديد مبلغ مخصص ترغب بسداده الآن</p>
                                    </div>
                                    <div class="ecp-type-check"><i class="fa fa-check" style="font-size:11px; display:none;"/></div>
                                </div>
                            </label>
                        </div>

                        <div class="ecp-actions">
                            <a class="ecp-btn ecp-btn-ghost" href="/"><i class="fa fa-arrow-right"/> رجوع</a>
                            <button type="submit" class="ecp-btn ecp-btn-primary">التالي <i class="fa fa-arrow-left"/></button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.ecp-type-card input').forEach(function (radio) {
                radio.addEventListener('change', function () {
                    document.querySelectorAll('.ecp-type-check i').forEach(function (icon) { icon.style.display = 'none'; });
                    var checked = document.querySelector('.ecp-type-card input:checked');
                    if (checked) {
                        var icon = checked.parentElement.querySelector('.ecp-type-check i');
                        if (icon) icon.style.display = 'block';
                    }
                });
            });
            var initial = document.querySelector('.ecp-type-card input:checked');
            if (initial) {
                var icon = initial.parentElement.querySelector('.ecp-type-check i');
                if (icon) icon.style.display = 'block';
            }
        });
        </script>
    </t>
</t>
