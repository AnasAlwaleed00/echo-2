<t name="Custom Portal Login" t-name="custom_portal_login.custom_login_template">
    <t>
        <div id="wrap" class="oe_structure">
            <!-- استدعاء خط كايرو من جوجل -->
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
            <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&amp;display=swap" rel="stylesheet"/>

            <style>
               :root{
                  --gold:#D4AF37;
                  --gold-dark:#B8860B;
                  --gold-light:#F4E27A;
                  --black:#151515;
                  --text:#202124;
                  --muted:#6B7280;
                  --border:#E5E7EB;
                  --bg:#F7F7F5;
                  --card:#FFFFFF;
                  --shadow:0 24px 70px rgba(17,24,39,.14);
                  --radius:28px;
                  font-family:"Tajawal","Cairo","IBM Plex Sans Arabic",system-ui,sans-serif;
                }
                *{box-sizing:border-box}
                body{margin:0;background:linear-gradient(180deg,#fff 0%,var(--bg) 100%);color:var(--text)}
                a{color:var(--gold-dark);text-decoration:none}
                button,input,select{font:inherit}
                .page-shell{width:min(1440px,100%);margin:auto;padding:24px}
                .login-layout{min-height:720px;border:1px solid #ddd;border-radius:30px;overflow:hidden;display:grid;grid-template-columns:1.1fr .9fr;background:#fff;box-shadow:var(--shadow)}
                .hero-panel{position:relative;min-height:720px;padding:42px 54px;display:flex;flex-direction:column;justify-content:space-between;background:linear-gradient(90deg,rgba(255,255,255,.92) 0%,rgba(255,255,255,.72) 38%,rgba(255,255,255,.08) 100%),url('assets/hero-building.jpeg') center/cover no-repeat}
                .hero-panel:after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 70% 20%,rgba(244,226,122,.22),transparent 32%),linear-gradient(180deg,transparent 55%,rgba(0,0,0,.46));pointer-events:none}
                .topbar,.hero-content,.hero-features{position:relative;z-index:1}.topbar{display:flex;justify-content:space-between;align-items:flex-start}.brand-logo{width:260px;mix-blend-mode:multiply}.language-btn{border:1px solid rgba(0,0,0,.08);background:rgba(255,255,255,.82);backdrop-filter:blur(14px);border-radius:999px;padding:10px 18px;display:inline-flex;gap:8px;align-items:center;cursor:pointer}.language-btn.small{font-size:13px;padding:7px 10px}.hero-content{max-width:460px;margin-top:auto;margin-bottom:70px}.hero-content h1{font-size:46px;line-height:1.3;margin:0 0 22px;font-weight:800}.hero-content span{color:var(--gold-dark)}.hero-content p{font-size:22px;line-height:1.8;margin:0;color:#2f343a}.hero-features{display:flex;gap:58px;color:#fff;text-align:center}.feature-item span{display:block;color:var(--gold);font-size:34px;margin-bottom:8px}.feature-item strong{font-size:18px}.form-panel{display:flex;flex-direction:column;justify-content:center;gap:18px;padding:48px;background:linear-gradient(180deg,rgba(255,255,255,.94),rgba(255,255,255,.98))}.mobile-topbar{display:none}.login-card{background:var(--card);border:1px solid rgba(0,0,0,.06);border-radius:var(--radius);box-shadow:0 18px 55px rgba(0,0,0,.13);padding:42px 46px}.login-card h2{text-align:center;margin:0 0 8px;font-size:30px}.subtitle{text-align:center;color:var(--muted);margin:0 0 30px}.field-label{display:block;font-weight:700;margin:15px 0 8px}.input-control{position:relative}.input-control input,.input-control select{width:100%;height:54px;border:1px solid var(--border);border-radius:12px;background:#fff;padding:0 18px;color:var(--text);outline:none;transition:.2s}.input-control input{padding-left:52px}.input-control select{appearance:none;color:#555}.input-control input:focus,.input-control select:focus{border-color:var(--gold);box-shadow:0 0 0 4px rgba(212,175,55,.14)}.select-control:before{content:"⌄";position:absolute;left:18px;top:50%;transform:translateY(-50%);z-index:1;color:#555}.field-icon{position:absolute;left:16px;top:50%;transform:translateY(-50%);color:#777}.icon-button{border:0;background:transparent;cursor:pointer}.form-row{display:flex;align-items:center;justify-content:space-between;margin:16px 0 22px;font-size:14px}.remember{display:flex;gap:8px;align-items:center;color:#333}.primary-btn{width:100%;height:58px;border:0;border-radius:12px;background:linear-gradient(135deg,var(--gold-dark),var(--gold),var(--gold-dark));color:#fff;font-weight:800;font-size:18px;cursor:pointer;box-shadow:0 12px 24px rgba(180,128,11,.22)}.divider{display:flex;align-items:center;gap:16px;color:#777;margin:18px 0}.divider:before,.divider:after{content:"";height:1px;background:#e5e5e5;flex:1}.outline-btn{height:56px;border:1.5px solid var(--gold);border-radius:12px;display:flex;align-items:center;justify-content:center;font-weight:700;background:#fff;color:var(--gold-dark)}.quick-actions{display:flex;gap:12px;justify-content:center}.quick-action{min-width:120px;height:52px;border-radius:16px;background:#fff;box-shadow:0 8px 28px rgba(0,0,0,.08);display:flex;align-items:center;justify-content:center;gap:8px;color:#222}.trust-strip{margin:24px auto 10px;max-width:960px;background:#fff;border-radius:18px;box-shadow:0 10px 32px rgba(0,0,0,.07);display:grid;grid-template-columns:repeat(3,1fr);overflow:hidden}.trust-strip div{padding:22px 30px;display:grid;grid-template-columns:auto 1fr;column-gap:12px;border-left:1px solid #eee}.trust-strip div:last-child{border-left:0}.trust-strip span{grid-row:span 2;color:var(--gold);font-size:30px}.trust-strip strong{font-size:18px}.trust-strip small{color:var(--muted)}.footer{text-align:center;color:#72757d;font-size:14px;padding:18px}.footer div{margin-top:8px}
                @media (max-width:1100px){.page-shell{padding:18px}.login-layout{grid-template-columns:1fr;min-height:auto}.hero-panel{min-height:420px;padding:28px;background:linear-gradient(180deg,rgba(255,255,255,.30),rgba(0,0,0,.45)),url('assets/hero-building.jpeg') center/cover no-repeat}.desktop-only{display:none}.hero-content{margin:auto 0 24px;max-width:520px;color:#fff}.hero-content h1{font-size:36px;color:#fff}.hero-content p{color:#fff;font-size:18px}.hero-features{display:none}.form-panel{margin-top:-95px;position:relative;z-index:5;padding:0 38px 34px;background:transparent}.mobile-topbar{display:flex;position:absolute;top:-320px;left:24px;right:24px;align-items:center;justify-content:space-between}.mobile-logo{width:160px;mix-blend-mode:multiply}.menu-btn{border:0;background:rgba(255,255,255,.86);border-radius:12px;padding:8px 12px}.login-card{padding:34px}.quick-actions{margin-top:8px}.trust-strip{grid-template-columns:1fr 1fr 1fr}}
                @media (max-width:640px){.page-shell{padding:0}.login-layout{border:0;border-radius:0;box-shadow:none}.hero-panel{min-height:390px;padding:18px;background-position:center top}.hero-content{text-align:center;margin-top:100px;margin-bottom:30px}.hero-content h1{font-size:28px}.hero-content p{font-size:14px}.form-panel{margin-top:-54px;padding:0 14px 20px}.mobile-topbar{top:-335px;left:14px;right:14px}.mobile-logo{width:124px}.login-card{border-radius:24px;padding:26px 18px}.login-card h2{font-size:24px}.subtitle{font-size:13px;margin-bottom:20px}.input-control input,.input-control select{height:48px;font-size:13px}.form-row{font-size:12px}.primary-btn,.outline-btn{height:50px}.quick-actions{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}.quick-action{min-width:0;height:58px;border-radius:14px;flex-direction:column;font-size:12px}.trust-strip{margin:10px 14px;grid-template-columns:1fr;box-shadow:none;border:1px solid #eee}.trust-strip div{border-left:0;border-bottom:1px solid #eee;padding:16px}.footer{font-size:12px;padding-bottom:24px}}

            </style>
            
            <section>
                <section class="login-layout" aria-label="تسجيل دخول العملاء">
                  <div class="hero-panel">
                    <header class="topbar desktop-only">
                      <!--<img class="brand-logo" src="/web/image/575938-626ce75c/hero-building.webp" alt="ORISA"/>-->
                     
                    </header>
            
                    <div class="hero-content">
                      <img class="hero-img" src="/web/image/575938-626ce75c/hero-building.webp" alt="ORISA"/>
                    </div>
            
                   
                  </div>
            
                  <div class="form-panel">
                    <header class="mobile-topbar">
                      <button class="menu-btn" type="button" aria-label="القائمة">☰</button>
                      <img class="mobile-logo" src="/web/image/575938-626ce75c/hero-building.webp" alt="ORISA"/>
                      <button class="language-btn small" type="button" aria-label="تغيير اللغة">
                        <span>🌐</span><span>العربية</span>
                      </button>
                    </header>
            
                    <form class="login-card" action="#" method="post">
                      <h2>تسجيل الدخول</h2>
                      <p class="subtitle">مرحباً بك، يرجى تسجيل الدخول للمتابعة</p>
            
                      <label class="field-label" for="branch">فرع القسم</label>
                      <div class="input-control select-control">
                        <select id="branch" name="branch">
                          <option value="">اختر الفرع التابع لك</option>
                          <option>فرع القصيم</option>
                          <option>فرع الرياض</option>
                          <option>فرع جدة</option>
                        </select>
                      </div>
            
                      <label class="field-label" for="customerNumber">رقم العميل</label>
                      <div class="input-control">
                        <input id="customerNumber" name="customerNumber" type="tel" inputmode="numeric" placeholder="أدخل آخر 4 أرقام من رقم العميل" maxlength="4"/>
                        <span class="field-icon">👤</span>
                      </div>
            
                      <label class="field-label" for="password">كلمة المرور</label>
                      <div class="input-control">
                        <input id="password" name="password" type="password" placeholder="أدخل كلمة المرور"/>
                        <button class="field-icon icon-button" type="button" aria-label="إظهار كلمة المرور">◉</button>
                      </div>
            
                      <div class="form-row">
                        <label class="remember"><input type="checkbox"/> تذكرني</label>
                        <a href="#">إعادة تعيين كلمة المرور</a>
                      </div>
            
                      <button class="primary-btn" type="submit">دخول</button>
            
                      <div class="divider"><span>أو</span></div>
            
                      <a class="outline-btn" href="#">📁 فتح ملف جديد</a>
                    </form>
            
                    <nav class="quick-actions" aria-label="روابط سريعة">
                      <a href="#" class="quick-action">📞 <span>اتصال</span></a>
                      <a href="#" class="quick-action whatsapp">🟢 <span>واتساب</span></a>
                      <a href="#" class="quick-action">👤 <span>دخول كزائر</span></a>
                    </nav>
                  </div>
                </section>

                <section class="trust-strip" aria-label="معلومات إضافية">
                  <div><span>🛡</span><strong>أمان عالي</strong><small>حماية بياناتك وضمان خصوصيتك</small></div>
                  <div><span>🎧</span><strong>دعم فني</strong><small>فريق دعم جاهز لمساعدتك</small></div>
                  <div><span>🕘</span><strong>متاح 24/7</strong><small>نحن هنا لخدمتك دائماً</small></div>
                </section>
            
                <footer class="footer">
                  جميع الحقوق محفوظة لشركة Echo Emaar Trading Company
                  <div><a href="#">سياسة الخصوصية</a> <span>|</span> <a href="#">الشروط والأحكام</a></div>
                </footer>
            </section>


            
            

            
        </div>
    </t>
</t>