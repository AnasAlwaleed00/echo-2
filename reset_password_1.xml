<t name="Reset Password" t-name="website_vat_reset.reset_password_page_1">
    <t>
        <div id="wrap" class="oe_structure">
            <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
            <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&amp;display=swap" rel="stylesheet"/>

            <style>
              *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
                :root {
                  --gold: #C9982A; --gold-dark: #A87B1E; --gold-light: rgba(201,152,42,0.15);
                  --navy: #0D1B2E; --white: #FFFFFF;
                  --text-muted: #8A8A8A; --border: #E2DDD4; --input-bg: #FAFAF8;
                }
                html, body, #wrap { font-family: "Cairo", sans-serif; background: #000; color: var(--white); overflow: hidden; height: 100%; width: 100%; overscroll-behavior: none; }
                .d-none { display: none !important; }

                /* ── HERO ── */
                .hero-section { position: relative; height: 100svh; height: 100dvh; display: flex; flex-direction: column; overflow: hidden; max-height: 100svh; max-height: 100dvh; }
                .hero-bg { position: absolute; inset: 0; z-index: 0; background: var(--navy); }
                .hero-bg img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
                @media (min-width: 961px) {
                  .hero-bg img { object-position: 102% 10%; }
                }
                .hero-bg::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to left, rgba(13,27,46,0.15) 0%, rgba(13,27,46,0.5) 38%, rgba(13,27,46,0.9) 100%); }

                /* ── HERO BODY ── */
                .hero-body { position: relative; z-index: 10; flex: 1; min-height: 0; display: flex; align-items: center; justify-content: space-between; padding: 20px 60px 20px; gap: 40px; overflow-y: auto; }
                .hero-copy { flex: 1; max-width: 520px; }
                .hero-title { font-size: 54px; font-weight: 700; color: var(--white); line-height: 1.15; margin-bottom: 14px; }
                .hero-title em { font-style: normal; color: var(--gold); font-weight: 900; display: block; }
                .hero-desc { font-size: 15px; color: rgba(255,255,255,0.65); line-height: 1.85; margin-bottom: 36px; }

                /* ── RESET CARD ── */
                .login-card { width: 420px; flex-shrink: 0; background: var(--white); border-radius: 18px; padding: 8px 30px 12px; direction: rtl; }
                .card-head { text-align: center; margin-bottom: 8px; }
                .card-title { font-size: 22px; font-weight: 800; color: var(--navy); margin-bottom: 5px; }
                .card-sub { font-size: 13px; color: var(--text-muted); }
                .field { margin-bottom: 2px; }
                .field-label { display: block; font-size: 13px; font-weight: 700; color: #2a2a2a; margin-bottom: 7px; }
                .required { color: #c0392b; }
                .input-wrap { position: relative; }
                .field-input, .field-select { width: 100%; height: 44px; border: 1.5px solid var(--border); border-radius: 10px; padding: 0 14px 0 42px; font-family: "Cairo", sans-serif; font-size: 16px; color: #333; background: var(--input-bg); direction: rtl; text-align: right; outline: none; appearance: none; transition: border-color 0.2s, box-shadow 0.2s; }
                .login-card input:not([type="checkbox"]), .login-card select, .login-card textarea { font-size: 16px; }
                .field-input::placeholder { color: #c5bfb5; }
                .field-input:focus, .field-select:focus { border-color: var(--gold); background: #fff; box-shadow: 0 0 0 3px rgba(201,152,42,0.12); }
                .in-icon { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); color: #c5bfb5; display: flex; align-items: center; pointer-events: none; }
                .in-icon svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
                .btn-login { width: 100%; height: 48px; background: var(--gold); border: none; border-radius: 10px; font-family: "Cairo", sans-serif; font-size: 16px; font-weight: 800; color: var(--white); cursor: pointer; transition: background 0.2s, transform 0.1s; margin-bottom: 4px; letter-spacing: 0.5px; }
                .btn-login:hover { background: var(--gold-dark); }
                .btn-login:active { transform: scale(0.98); }
                .btn-login.btn-success { background: #2e9e4d; }
                .btn-login.btn-success:hover { background: #25843f; }
                #msg_error.alert { margin-bottom: 14px; padding: 10px 14px; border-radius: 10px; font-size: 13px; border: 1px solid #f5c2c7; background: #fde8ea; color: #842029; text-align: center; }
                .step-title { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
                .step-badge { width: 28px; height: 28px; background: var(--input-bg); border: 1.5px solid var(--border); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 800; color: var(--text-muted); flex-shrink: 0; }
                .active-step .step-badge { background: var(--gold); border-color: var(--gold); color: var(--white); }
                .info-box { background: var(--gold-light); border: 1px solid rgba(201,152,42,0.25); border-radius: 10px; padding: 12px 14px; margin-bottom: 16px; text-align: center; font-size: 13px; color: #444; }
                .info-box-row { display: flex; flex-direction: row-reverse; justify-content: center; align-items: center; gap: 6px; }
                .info-box strong { color: var(--navy); font-size: 16px; letter-spacing: 2px; direction: ltr; display: inline-block; }
                .mobile-row { display: flex; direction: ltr; margin-bottom: 16px; }
                .mobile-prefix { display: flex; align-items: center; justify-content: center; padding: 0 14px; height: 44px; background: var(--input-bg); border: 1.5px solid var(--border); border-radius: 10px 0 0 10px; font-size: 14px; font-weight: 700; color: #555; border-right: none; flex-shrink: 0; }
                .mobile-row .field-input { border-radius: 0 10px 10px 0; text-align: center; padding: 0 14px; }
                .field-input.otp-input { text-align: center; letter-spacing: 8px; font-size: 20px; font-weight: 800; padding: 0 14px; }
                .back-link { display: block; text-align: center; margin-top: 16px; font-size: 12.5px; color: var(--text-muted); text-decoration: none; }
                .back-link:hover { color: var(--gold); }

                /* ── FOOTER BAR ── */
                .footer-strip { position: relative; z-index: 10; flex-shrink: 0; display: flex; flex-direction: column; gap: 14px; padding: 12px 60px max(20px, env(safe-area-inset-bottom)); }
                .footer-bar { border-radius: 60px; display: flex; overflow: hidden; border: 1px solid rgba(255,255,255,0.18); }
                .footer-btn {
                  flex: 1; display: flex; align-items: center; justify-content: center; gap: 10px;
                  padding: 2px 10px; background: rgba(255,255,255,0.08);
                  border: none; border-left: 1px solid rgba(255,255,255,0.12);
                  font-family: "Cairo", sans-serif; font-size: 14px; font-weight: 600;
                  color: rgba(255,255,255,0.9); cursor: pointer; direction: rtl;
                  transition: background 0.2s, color 0.2s; text-decoration: none;
                }
                .footer-btn:first-child { background: rgba(255,255,255,0.05); }
                .footer-btn:last-child { border-left: none; background: rgba(255,255,255,0.05); }
                .footer-btn:hover { background: rgba(255,255,255,0.15); color: #fff; }
                .footer-btn .btn-icon { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
                .footer-btn:first-child .btn-icon { background: rgba(201,152,42,0.2); border: 1px solid rgba(201,152,42,0.4); }
                .footer-btn:last-child .btn-icon { background: rgba(201,152,42,0.2); border: 1px solid rgba(201,152,42,0.4); }
                .footer-btn.wa .btn-icon { background: rgba(37,211,102,0.15); border: 1px solid rgba(37,211,102,0.35); }
                .footer-btn svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round; }
                .footer-btn:first-child svg, .footer-btn:last-child svg { stroke: var(--gold); }
                .footer-btn.wa svg { stroke: #25D366; }
                .btn-label { display: flex; flex-direction: column; align-items: flex-end; gap: 1px; }
                .btn-label span { font-size: 14px; font-weight: 700; }
                .btn-label small { font-size: 11px; color: rgba(255,255,255,0.5); font-weight: 400; }

                /* ── PAGE FOOTER ── */
                .page-footer { display: none; }
                .footer-copy { font-size: 11px; color: rgba(255,255,255,0.45); text-align: center; }
                .footer-links { display: flex; gap: 24px; align-items: center; }
                .footer-links a { font-size: 11px; color: rgba(255,255,255,0.55); text-decoration: none; }
                .footer-links a:hover { color: var(--gold); }
                .footer-sep { color: rgba(255,255,255,0.25); font-size: 11px; }

                @media (max-width: 960px) {
                  .hero-bg img { object-position: 73% 10%; }
                  .hero-body { padding: 20px 24px 14px; flex-direction: column; align-items: center; gap: 24px; }
                  .hero-copy { max-width: 100%; width: 100%; text-align: right; flex: none; }
                  .hero-title { font-size: 36px; }
                  .login-card { width: 100%; max-width: 480px; padding: 12px 30px 12px; }
                  .footer-strip { padding: 10px 24px 16px; gap: 12px; }
                }
                @media (max-width: 540px) {
                  html, body, #wrap { position: fixed; inset: 0; }
                  .hero-section { height: 100%; max-height: 100%; }
                  .hero-bg img { object-position: 68% 10%; }
                  .hero-body { padding: 16px 18px 10px; gap: 18px; }
                  .hero-title { font-size: 28px; margin-bottom: 0; }
                  .hero-desc { display: none; }
                  .login-card { padding: 12px 18px 14px; border-radius: 14px; }
                  .card-title { font-size: 19px; }
                  .footer-strip { padding: 8px 18px max(14px, env(safe-area-inset-bottom)); gap: 10px; }
                  .footer-btn { font-size: 12.5px; padding: 12px 8px; gap: 4px; }
                  .footer-btn .btn-icon { width: 28px; height: 28px; }
                  .footer-btn svg { width: 15px; height: 15px; }
                  .btn-label span { font-size: 12.5px; }
                  .btn-label small { display: none; }
                }
            </style>

            <div class="hero-section">
              <div class="hero-bg">
                <img src="https://res.cloudinary.com/quizat/image/upload/v1781455952/echo-building-4_kgaohf.png" alt="ORISA Building"/>
              </div>

              <div class="hero-body">
                <div class="hero-copy">
                  <h1 class="hero-title">أوريسا خبرة تدعم <em>نجاح مشاريعك</em></h1>
                </div>

                <div class="login-card">
                  <div class="card-head">
                    <h2 class="card-title">استعادة الحساب</h2>
                    <!-- <p class="card-sub">يرجى اتباع الخطوات لتأمين حسابك</p> -->
                  </div>

                  <div id="msg_error" class="alert alert-danger d-none"/>

                  <!-- Step 1 -->
                  <div id="step_1" class="step-container active-step">
                    <h5 class="step-title"><span class="step-badge">1</span> التحقق من الهوية</h5>
                    <div class="field">
                      <label class="field-label" for="branch_select">الفرع <span class="required">*</span></label>
                      <div class="input-wrap">
                        <select id="branch_select" class="field-input field-select">
                          <option value="">-- اختر الفرع --</option>
                          <option value="JED(121012)-">جدة</option>
                          <option value="RYDH(121011)-">الرياض</option>
                          <option value="KHAM(121013)-">خميس مشيط</option>
                          <option value="QAS(121015)-">القصيم</option>
                          <option value="JAZ(121014)-">جازان</option>
                        </select>
                        <span class="in-icon"><svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg></span>
                      </div>
                    </div>
                    <div class="field">
                      <label class="field-label" for="input_ref">رقم العميل (4 أرقام) <span class="required">*</span></label>
                      <div class="input-wrap">
                        <input type="text" id="input_ref" class="field-input" maxlength="4" placeholder="* يرجى إدخال آخر 4 أرقام من رقم العميل"/>
                        <span class="in-icon"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                      </div>
                    </div>
                    <div class="field">
                      <label class="field-label" for="input_id">رقم السجل التجاري أو الرقم الموحد (700) <span class="required">*</span></label>
                      <div class="input-wrap">
                        <input type="text" id="input_id" class="field-input" placeholder="مثال: 700xxxxxxxx"/>
                        <span class="in-icon"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 8h10M7 12h6"/></svg></span>
                      </div>
                    </div>
                    <button class="btn-login" type="button" id="btn_verify_id">تحقق من البيانات</button>
                  </div>

                  <!-- Step 2 -->
                  <div id="step_2" class="d-none step-container">
                    <h5 class="step-title"><span class="step-badge">2</span> تأكيد الجوال</h5>
                    <div class="info-box">
                      <div class="info-box-row">
                        <span>اكتب رقم الجوال المنتهي بـ:</span>
                        <strong id="display_masked" dir="ltr"/>
                      </div>
                    </div>
                    <div class="mobile-row">
                      <span class="mobile-prefix">966+</span>
                      <input type="text" id="input_mobile" class="field-input" placeholder="5xxxxxxxx"/>
                    </div>
                    <button class="btn-login btn-success" type="button" id="btn_send_otp">إرسال كود التحقق (OTP)</button>
                  </div>

                  <!-- Step 3 -->
                  <div id="step_3" class="d-none step-container">
                    <h5 class="step-title"><span class="step-badge">3</span> رمز التحقق</h5>
                    <div class="field">
                      <label class="field-label" for="input_otp">أدخل الرمز المكون من 6 أرقام</label>
                      <input type="text" id="input_otp" class="field-input otp-input" maxlength="6"/>
                    </div>
                    <button class="btn-login" type="button" id="btn_verify_otp">تأكيد الرمز</button>
                  </div>

                  <!-- Step 4 -->
                  <div id="step_4" class="d-none step-container">
                    <h5 class="step-title"><span class="step-badge">4</span> تعيين كلمة المرور</h5>
                    <div class="field">
                      <label class="field-label" for="new_password">كلمة المرور الجديدة</label>
                      <div class="input-wrap">
                        <input type="password" id="new_password" class="field-input"/>
                        <span class="in-icon"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg></span>
                      </div>
                    </div>
                    <div class="field">
                      <label class="field-label" for="confirm_password">تأكيد كلمة المرور</label>
                      <div class="input-wrap">
                        <input type="password" id="confirm_password" class="field-input"/>
                        <span class="in-icon"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg></span>
                      </div>
                    </div>
                    <button class="btn-login btn-success" type="button" id="btn_finish">تحديث الحساب والولوج</button>
                  </div>

                  <a href="/custom/login" class="back-link">العودة لتسجيل الدخول</a>
                </div>
              </div>

              <div class="footer-strip">
                <div class="footer-bar">
                  <a href="tel:+966920000136" class="footer-btn">
                    <div class="btn-icon"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg></div>
                    <div class="btn-label"><span>اتصال</span><small>تواصل معنا مباشرة</small></div>
                  </a>
                  <a href="https://wa.me/966920000136" class="footer-btn wa" target="_blank" rel="noopener noreferrer">
                    <div class="btn-icon"><svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg></div>
                    <div class="btn-label"><span>واتساب</span><small>راسلنا على واتساب</small></div>
                  </a>
                  <a href="/" class="footer-btn">
                    <div class="btn-icon"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
                    <div class="btn-label"><span>دخول كزائر</span><small>تصفح بدون حساب</small></div>
                  </a>
                </div>
                <footer class="page-footer">
                  <p class="footer-copy">جميع الحقوق محفوظة لشركة Echo Emaar Trading Company</p>
                  <div class="footer-links">
                    <a href="#">سياسة الخصوصية</a>
                    <span class="footer-sep">|</span>
                    <a href="#">الشروط والأحكام</a>
                  </div>
                </footer>
              </div>
            </div>

            <script type="text/javascript" src="/website_vat_reset/static/src/js/password_reset.js"/>
        </div>
    </t>
</t>
